@model List<AkkuChatbot.Controllers.SoftwareItem>
@{
    ViewData["Title"] = "Free Software Downloads";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid px-4 mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h3 class="fw-bold">💻 Free Software Downloads</h3>
            <p class="text-muted">Handpicked freeware and open source tools for Windows</p>
        </div>
        <div class="col-md-4">
            <form method="get">
                <div class="input-group">
                    <input type="text" name="search" value="@ViewBag.Search"
                           class="form-control" placeholder="Search software…" />
                    <button class="btn btn-primary"><i class="fa fa-search"></i></button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-3">
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-warning">
                    No software catalog found. Please create <code>wwwroot/data/software-catalog.json</code>
                </div>
            </div>
        }
        else
        {
            @foreach (var s in Model)
            {
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 bg-dark border-secondary">
                        <div class="card-body">
                            <h5 class="card-title">
                                <span style="font-size:1.5rem">@s.Icon</span> @s.Name
                            </h5>
                            <p class="card-text small text-muted">@s.Description</p>
                            <div class="d-flex gap-2 mb-2 flex-wrap">
                                <span class="badge bg-success small">@s.License</span>
                                <span class="badge bg-secondary small">v@s.Version</span>
                                <span class="badge bg-info small">@(s.FileSizeMB)MB</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a href="/Software/Details/@s.Id" class="btn btn-sm btn-outline-secondary flex-fill">
                                    Details
                                </a>
                                <a href="@s.DownloadUrl" target="_blank" class="btn btn-sm btn-primary flex-fill">
                                    <i class="fa fa-download"></i> Get
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="mt-4">
        <a href="/" class="btn btn-secondary">← Back to Home</a>
    </div>
</div>
