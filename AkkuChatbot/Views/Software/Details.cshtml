@model AkkuChatbot.Controllers.SoftwareItem
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:800px">
    <a href="/Software" class="btn btn-sm btn-outline-secondary mb-3">← Back to Software</a>

    <div class="card bg-dark border-secondary">
        <div class="card-body">
            <div class="d-flex align-items-center gap-3 mb-3">
                <span style="font-size:3rem">@Model.Icon</span>
                <div>
                    <h3 class="mb-1">@Model.Name</h3>
                    <div class="d-flex gap-2">
                        <span class="badge bg-success">@Model.License</span>
                        <span class="badge bg-secondary">v@Model.Version</span>
                        <span class="badge bg-info">@(Model.FileSizeMB)MB</span>
                    </div>
                </div>
            </div>

            <p class="mb-3">@Model.Description</p>

            <div class="row g-2 mb-3 small text-muted">
                <div class="col-6"><strong>Category:</strong> @Model.Category</div>
                <div class="col-6"><strong>Updated:</strong> @Model.UpdatedAt.ToString("dd MMM yyyy")</div>
                <div class="col-6"><strong>Downloads:</strong> @Model.Downloads.ToString("N0")</div>
            </div>

            <div class="d-flex gap-3">
                <a href="@Model.DownloadUrl" target="_blank" class="btn btn-primary">
                    <i class="fa fa-download"></i> Download Now
                </a>
            </div>
        </div>
    </div>
</div>
