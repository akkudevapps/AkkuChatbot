@model List<AkkuChatbot.Models.ChatSession>
@{
    ViewData["Title"] = "Sessions";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    int total    = ViewBag.Total ?? 0;
    int page     = ViewBag.Page  ?? 1;
    int pageSize = ViewBag.PageSize ?? 20;
    string? search = ViewBag.Search;
    int totalPages = (int)Math.Ceiling(total / (double)pageSize);
}

<style>
/* ── Group-by tabs ───────────────────────────────────── */
.grp-tabs { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:16px; }
.grp-tab  {
    padding:5px 14px; border-radius:20px; font-size:.78rem; font-weight:600;
    border:1px solid #30363d; background:#21262d; color:#8b949e;
    cursor:pointer; transition:all .15s; user-select:none;
}
.grp-tab:hover  { border-color:#58a6ff; color:#58a6ff; }
.grp-tab.active { background:#1f2d45; border-color:#2f81f7; color:#2f81f7; }

/* ── Bulk-action bar ─────────────────────────────────── */
.bulk-bar {
    display:none; align-items:center; gap:10px;
    background:#1f2d45; border:1px solid #2f81f7;
    border-radius:8px; padding:8px 14px; margin-bottom:14px;
    font-size:.83rem; animation:slideIn .2s ease;
}
.bulk-bar.show { display:flex; }
@@keyframes slideIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }

/* ── Group header rows ───────────────────────────────── */
.grp-header {
    background:#21262d; padding:8px 12px;
    font-size:.73rem; font-weight:700; color:#8b949e;
    text-transform:uppercase; letter-spacing:.5px;
    display:flex; align-items:center; gap:8px;
    border-top:1px solid #30363d;
}
.grp-header .grp-count {
    background:#30363d; color:#8b949e; padding:1px 7px;
    border-radius:10px; font-size:.68rem; font-weight:600;
}
.grp-toggle { cursor:pointer; color:#58a6ff; font-size:.75rem; margin-left:auto; }

/* ── Row hidden when group collapsed ─────────────────── */
.grp-row.collapsed { display:none; }

/* ── Checkbox column ─────────────────────────────────── */
.chk-col { width:38px; text-align:center; }
.form-check-input { width:15px; height:15px; cursor:pointer; }
.form-check-input:checked { background-color:#2f81f7; border-color:#2f81f7; }

/* ── Date badge ──────────────────────────────────────── */
.date-badge {
    font-size:.72rem; color:#8b949e;
    background:#21262d; border-radius:5px;
    padding:1px 6px; white-space:nowrap;
}

/* ── Danger confirm modal ────────────────────────────── */
.modal-danger .modal-content { background:#1a0a0a; border:1px solid #f85149; color:#e6edf3; }
.modal-danger .modal-header  { border-color:#3d1a1a; }
.modal-danger .modal-footer  { border-color:#3d1a1a; }

/* ── Filter row ──────────────────────────────────────── */
.filter-row { display:flex; gap:10px; flex-wrap:wrap; align-items:center; margin-bottom:14px; }
.filter-input {
    background:#21262d; border:1px solid #30363d; color:#e6edf3;
    padding:6px 11px; border-radius:7px; font-size:.8rem;
}
.filter-input:focus { outline:none; border-color:#2f81f7; }
.filter-input::placeholder { color:#484f58; }

/* ── Highlight matched search text ──────────────────── */
mark { background:#2d3a18; color:#d2a679; border-radius:2px; padding:0 2px; }

/* ── Session count pill ──────────────────────────────── */
.cnt-pill { background:#1f2d45; color:#58a6ff; padding:2px 8px; border-radius:10px; font-size:.72rem; font-weight:600; }

/* ── Model chip ──────────────────────────────────────── */
.model-chip {
    display:inline-block; padding:1px 7px; border-radius:10px; font-size:.68rem;
    background:#21262d; border:1px solid #30363d; color:#8b949e; max-width:130px;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle;
}

/* ── Empty state ─────────────────────────────────────── */
.empty-state { text-align:center; padding:48px 0; color:#484f58; }
.empty-state i { font-size:2.4rem; margin-bottom:10px; display:block; }
</style>

<!-- ═══════════════════ PAGE HEADER ═══════════════════ -->
<div class="d-flex align-items-center justify-content-between mb-3">
    <div class="page-title mb-0">
        <i class="fa fa-comments" style="color:#2f81f7"></i>
        Chat Sessions
        <span class="cnt-pill ms-1">@total total</span>
    </div>
    <div>
        <button id="btnBulkDelete" class="btn btn-sm btn-danger d-none"
                data-bs-toggle="modal" data-bs-target="#confirmModal">
            <i class="fa fa-trash me-1"></i> Delete Selected
        </button>
    </div>
</div>

<!-- ═══════════════════ FILTERS ════════════════════════ -->
<div class="filter-row">
    <form method="get" asp-action="Sessions" class="d-flex gap-2 flex-wrap align-items-center">
        <input name="search" value="@search" placeholder="🔍  Search sessions or users…"
               class="filter-input" style="width:260px" autocomplete="off" />
        <input type="date" id="filterFrom" class="filter-input" placeholder="From" title="From date" />
        <input type="date" id="filterTo"   class="filter-input" placeholder="To"   title="To date" />
        <button type="submit" class="btn btn-sm btn-primary">Apply</button>
        @if (!string.IsNullOrEmpty(search))
        {
            <a href="/Admin/Sessions" class="btn btn-sm btn-outline-secondary">✕ Clear</a>
        }
    </form>
</div>

<!-- ═══════════════════ GROUP-BY TABS ══════════════════ -->
<div class="grp-tabs">
    <div class="grp-tab active" data-group="all">📋 All</div>
    <div class="grp-tab" data-group="user">👤 By User</div>
    <div class="grp-tab" data-group="date">📅 By Date</div>
    <div class="grp-tab" data-group="model">🤖 By Model</div>
</div>

<!-- ═══════════════════ BULK BAR ════════════════════════ -->
<div class="bulk-bar" id="bulkBar">
    <i class="fa fa-check-square" style="color:#2f81f7"></i>
    <span id="bulkCount" style="color:#e6edf3;font-weight:600">0</span>
    <span style="color:#8b949e">sessions selected</span>
    <button class="btn btn-sm btn-outline-secondary ms-1" id="btnDeselectAll">Deselect All</button>
    <button class="btn btn-sm btn-danger ms-auto" data-bs-toggle="modal" data-bs-target="#confirmModal">
        <i class="fa fa-trash me-1"></i> Delete Selected
    </button>
</div>

<!-- ═══════════════════ MAIN TABLE ═════════════════════ -->
<div class="admin-card">
    <div class="admin-card-head">
        <div class="d-flex align-items-center gap-3">
            <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="chkAll" title="Select all visible rows" />
                <label class="form-check-label small text-secondary" for="chkAll">All</label>
            </div>
            <span id="tableLabel" style="font-size:.85rem">
                Showing <strong style="color:#e6edf3">@Model.Count</strong> of <strong style="color:#e6edf3">@total</strong>
            </span>
        </div>
        <!-- pagination arrows -->
        <div class="d-flex gap-2 align-items-center">
            @if (page > 1)
            {
                <a href="?page=@(page-1)&search=@search" class="btn btn-xs btn-outline-secondary">
                    <i class="fa fa-chevron-left"></i>
                </a>
            }
            
            @if (page < totalPages)
            {
                <a href="?page=@(page+1)&search=@search" class="btn btn-xs btn-outline-secondary">
                    <i class="fa fa-chevron-right"></i>
                </a>
            }
        </div>
    </div>

    <table class="admin-table" id="sessionTable">
        <thead>
            <tr>
                <th class="chk-col"></th>
                <th>#</th>
                <th>Session Name</th>
                <th>User</th>
                <th>Model</th>
                <th>Msgs</th>
                <th>Tokens</th>
                <th>Coins</th>
                <th>Last Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="sessionBody">
        @foreach (var s in Model)
        {
            string email = s.User?.Email ?? "—";
            string userName = s.User?.UserName ?? email;
            string modelShort = s.ModelUsed?.Length > 20 ? s.ModelUsed[..20]+"…" : (s.ModelUsed ?? "—");
            string dateGroup = GetDateGroup(s.UpdatedAt);
            <tr class="session-row"
                data-id="@s.Id"
                data-user="@email"
                data-model="@(s.ModelUsed ?? "")"
                data-date="@s.UpdatedAt.ToString("yyyy-MM-dd")"
                data-dategroup="@dateGroup">
                <td class="chk-col">
                    <input class="form-check-input row-chk" type="checkbox" value="@s.Id" />
                </td>
                <td style="color:#484f58;font-size:.75rem">@s.Id</td>
                <td>
                    <a href="/Admin/SessionDetail/@s.Id"
                       style="color:#58a6ff;text-decoration:none;font-weight:500;font-size:.83rem">
                        @(s.Name?.Length > 40 ? s.Name[..40]+"…" : s.Name)
                    </a>
                    @if (s.IsArchived)
                    {
                        <span class="badge ms-1" style="background:#3d1a1a;color:#f85149;font-size:.65rem">archived</span>
                    }
                </td>
                <td>
                    <span style="color:#e6edf3;font-size:.8rem">@(s.User?.FullName ?? "—")</span>
                    <br/><span style="color:#484f58;font-size:.72rem">@email</span>
                </td>
                <td><span class="model-chip" title="@s.ModelUsed">@modelShort</span></td>
                <td style="color:#e6edf3;font-size:.82rem;font-weight:600">@s.TotalMessages</td>
                <td style="color:#8b949e;font-size:.78rem">@s.TotalTokensUsed.ToString("N0")</td>
                <td><span class="coin-pill">@s.TotalCoinsUsed 🪙</span></td>
                <td><span class="date-badge">@s.UpdatedAt.ToString("dd MMM yy HH:mm")</span></td>
                <td>
                    <div class="d-flex gap-1">
                        <a href="/Admin/SessionDetail/@s.Id"
                           class="btn btn-xs btn-outline-secondary" title="View">
                            <i class="fa fa-eye"></i>
                        </a>
                        <button class="btn btn-xs btn-outline-danger btn-single-delete"
                                data-id="@s.Id" data-name="@s.Name" title="Archive">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <i class="fa fa-comments-slash"></i>
            No sessions found.
        </div>
    }
</div>

<!-- ═══════════════════ CONFIRM DELETE MODAL ═══════════ -->
<div class="modal fade modal-danger" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-triangle-exclamation text-danger me-2"></i>Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p id="confirmMsg" style="color:#e6edf3;margin:0">
                    Archive <strong id="confirmCount" style="color:#f85149">0</strong> selected sessions?
                </p>
                <p class="small mt-2" style="color:#8b949e">
                    Sessions will be marked as archived and hidden from users. Data is not permanently deleted.
                </p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-sm btn-danger" id="btnConfirmDelete">
                    <i class="fa fa-trash me-1"></i> Yes, Archive
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════════ SINGLE DELETE MODAL ═══════════ -->
<div class="modal fade modal-danger" id="singleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa fa-triangle-exclamation text-danger me-2"></i>Archive Session</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p style="color:#e6edf3">Archive session: <strong id="singleName" style="color:#f85149"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form method="post" asp-controller="Admin" asp-action="DeleteSession" id="singleForm">
                    <input type="hidden" name="sessionId" id="singleId" />
                    <button type="submit" class="btn btn-sm btn-danger">
                        <i class="fa fa-trash me-1"></i> Archive
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
// ════════════════════════════════════════════════════════
//  AkkuAdmin — Sessions grouping + bulk delete
// ════════════════════════════════════════════════════════
(function () {
    // ── Element refs ─────────────────────────────────────
    const body      = document.getElementById('sessionBody');
    const chkAll    = document.getElementById('chkAll');
    const bulkBar   = document.getElementById('bulkBar');
    const bulkCount = document.getElementById('bulkCount');
    const btnDeselect = document.getElementById('btnDeselectAll');
    const confirmCount = document.getElementById('confirmCount');
    const filterFrom = document.getElementById('filterFrom');
    const filterTo   = document.getElementById('filterTo');

    // ── Raw rows ──────────────────────────────────────────
    const allRows = Array.from(document.querySelectorAll('.session-row'));

    // ── Current state ─────────────────────────────────────
    let currentGroup = 'all';
    let selectedIds  = new Set();

    // ════════════════════════════════════════════════════
    //  GROUPING ENGINE
    // ════════════════════════════════════════════════════
    function groupBy(rows, key) {
        const map = {};
        rows.forEach(r => {
            const val = r.dataset[key] || '—';
            (map[val] = map[val] || []).push(r);
        });
        return map;
    }

    function renderFlat(rows) {
        body.innerHTML = '';
        rows.forEach(r => { r.classList.remove('collapsed'); body.appendChild(r); });
    }

    function renderGrouped(rows, keyFn, labelFn) {
        body.innerHTML = '';
        const map = {};
        rows.forEach(r => {
            const k = keyFn(r);
            (map[k] = map[k] || []).push(r);
        });

        // Sort group keys (descending for date, alpha otherwise)
        const keys = Object.keys(map).sort((a, b) => {
            // date group order
            const dateOrder = ['Today','Yesterday','This Week','This Month','This Year','Older'];
            const ia = dateOrder.indexOf(a), ib = dateOrder.indexOf(b);
            if (ia >= 0 && ib >= 0) return ia - ib;
            return a.localeCompare(b);
        });

        keys.forEach(k => {
            const groupRows = map[k];
            const hdr = document.createElement('tr');
            hdr.innerHTML = `
                <td colspan="10" class="grp-header p-0">
                    <div class="grp-header" style="cursor:pointer" data-gkey="${k}">
                        <input class="form-check-input grp-chk" type="checkbox"
                               title="Select group" data-gkey="${k}" onclick="event.stopPropagation()" />
                        <span>${labelFn(k)}</span>
                        <span class="grp-count">${groupRows.length}</span>
                        <span class="grp-toggle"><i class="fa fa-chevron-down fa-xs"></i></span>
                    </div>
                </td>`;
            hdr.querySelector('.grp-header').addEventListener('click', function(e) {
                if (e.target.type === 'checkbox') return;
                toggleGroup(k);
            });
            body.appendChild(hdr);

            groupRows.forEach(r => {
                r.classList.remove('collapsed');
                r.dataset.grpKey = k;
                body.appendChild(r);
            });
        });

        // Wire group checkboxes
        document.querySelectorAll('.grp-chk').forEach(gc => {
            gc.addEventListener('change', function() {
                const gkey = this.dataset.gkey;
                document.querySelectorAll(`.session-row[data-grp-key="${gkey}"] .row-chk`)
                    .forEach(c => { c.checked = this.checked; });
                syncSelection();
            });
        });
    }

    function toggleGroup(key) {
        const rows = document.querySelectorAll(`.session-row[data-grp-key="${key}"]`);
        const first = rows[0];
        const collapsed = first && first.classList.contains('collapsed');
        rows.forEach(r => r.classList.toggle('collapsed', !collapsed));
        // flip chevron
        const icon = document.querySelector(`.grp-header[data-gkey="${key}"] .grp-toggle i`);
        if (icon) icon.className = collapsed ? 'fa fa-chevron-down fa-xs' : 'fa fa-chevron-right fa-xs';
    }

    // ── Render by current group ───────────────────────────
    function render() {
        let visible = getFilteredRows();
        if (currentGroup === 'all') {
            renderFlat(visible);
        } else if (currentGroup === 'user') {
            renderGrouped(visible, r => r.dataset.user, k => `👤 ${k}`);
        } else if (currentGroup === 'date') {
            renderGrouped(visible, r => r.dataset.dategroup, k => `📅 ${k}`);
        } else if (currentGroup === 'model') {
            renderGrouped(visible, r => {
                const m = r.dataset.model || '—';
                return m.split(':')[0]; // strip tag suffix
            }, k => `🤖 ${k}`);
        }
        syncSelection();
    }

    // ════════════════════════════════════════════════════
    //  DATE FILTER (client-side)
    // ════════════════════════════════════════════════════
    function getFilteredRows() {
        const from = filterFrom.value;
        const to   = filterTo.value;
        if (!from && !to) return allRows;
        return allRows.filter(r => {
            const d = r.dataset.date;
            if (from && d < from) return false;
            if (to   && d > to)   return false;
            return true;
        });
    }

    filterFrom.addEventListener('change', render);
    filterTo.addEventListener('change', render);

    // ════════════════════════════════════════════════════
    //  SELECTION TRACKING
    // ════════════════════════════════════════════════════
    function syncSelection() {
        selectedIds.clear();
        document.querySelectorAll('.row-chk:checked').forEach(c => selectedIds.add(c.value));
        const count = selectedIds.size;
        bulkCount.textContent = count;
        bulkBar.classList.toggle('show', count > 0);
        confirmCount.textContent = count;
        document.getElementById('btnBulkDelete')?.classList.toggle('d-none', count === 0);
        // sync header checkbox
        const total = document.querySelectorAll('.row-chk:not([disabled])').length;
        chkAll.checked = total > 0 && count === total;
        chkAll.indeterminate = count > 0 && count < total;
    }

    body.addEventListener('change', e => {
        if (e.target.classList.contains('row-chk')) syncSelection();
    });

    chkAll.addEventListener('change', function () {
        document.querySelectorAll('.row-chk').forEach(c => { c.checked = this.checked; });
        syncSelection();
    });

    btnDeselect.addEventListener('click', () => {
        document.querySelectorAll('.row-chk').forEach(c => c.checked = false);
        chkAll.checked = false;
        syncSelection();
    });

    // ════════════════════════════════════════════════════
    //  BULK DELETE (AJAX)
    // ════════════════════════════════════════════════════
    document.getElementById('btnConfirmDelete').addEventListener('click', async function () {
        if (selectedIds.size === 0) return;
        const ids = Array.from(selectedIds);

        this.disabled = true;
        this.innerHTML = '<i class="fa fa-spinner fa-spin me-1"></i> Archiving…';

        try {
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value
                       || getCookie('XSRF-TOKEN') || '';
            const res = await fetch('/Admin/BulkDeleteSessions', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ sessionIds: ids })
            });
            const data = await res.json();
            if (data.success) {
                // Remove archived rows from DOM
                ids.forEach(id => {
                    const row = document.querySelector(`.session-row[data-id="${id}"]`);
                    if (row) row.remove();
                });
                selectedIds.clear();
                syncSelection();
                bootstrap.Modal.getInstance(document.getElementById('confirmModal'))?.hide();
                showToast(`✅ ${data.archived} sessions archived.`, 'success');
                // update count pill
                const pill = document.querySelector('.cnt-pill');
                if (pill) pill.textContent = `${parseInt(pill.textContent) - data.archived} total`;
            } else {
                showToast('❌ ' + (data.error || 'Failed'), 'danger');
            }
        } catch (err) {
            showToast('❌ Network error: ' + err.message, 'danger');
        } finally {
            this.disabled = false;
            this.innerHTML = '<i class="fa fa-trash me-1"></i> Yes, Archive';
        }
    });

    // ════════════════════════════════════════════════════
    //  SINGLE DELETE
    // ════════════════════════════════════════════════════
    document.querySelectorAll('.btn-single-delete').forEach(btn => {
        btn.addEventListener('click', function () {
            document.getElementById('singleId').value   = this.dataset.id;
            document.getElementById('singleName').textContent = this.dataset.name;
            new bootstrap.Modal(document.getElementById('singleModal')).show();
        });
    });

    // ════════════════════════════════════════════════════
    //  GROUP TABS
    // ════════════════════════════════════════════════════
    document.querySelectorAll('.grp-tab').forEach(tab => {
        tab.addEventListener('click', function () {
            document.querySelectorAll('.grp-tab').forEach(t => t.classList.remove('active'));
            this.classList.add('active');
            currentGroup = this.dataset.group;
            chkAll.checked = false;
            render();
        });
    });

    // ════════════════════════════════════════════════════
    //  HELPERS
    // ════════════════════════════════════════════════════
    function showToast(msg, type) {
        const t = document.createElement('div');
        t.style.cssText = `
            position:fixed;bottom:20px;right:20px;z-index:9999;
            background:${type==='success'?'#1a3a1a':'#3d1a1a'};
            border:1px solid ${type==='success'?'#3fb950':'#f85149'};
            color:${type==='success'?'#3fb950':'#f85149'};
            padding:10px 18px;border-radius:8px;font-size:.83rem;
            box-shadow:0 4px 12px rgba(0,0,0,.5);animation:slideIn .2s ease;`;
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 4000);
    }

    function getCookie(name) {
        return document.cookie.split(';')
            .map(c => c.trim()).find(c => c.startsWith(name+'='))?.split('=')[1] ?? '';
    }

    // ── Initial render ────────────────────────────────────
    render();

})();
</script>

@functions {
    static string GetDateGroup(DateTime d) {
        var now = DateTime.UtcNow.Date;
        var date = d.Date;
        if (date == now) return "Today";
        if (date == now.AddDays(-1)) return "Yesterday";
        if (date >= now.AddDays(-7)) return "This Week";
        if (date >= now.AddDays(-30)) return "This Month";
        if (date.Year == now.Year) return "This Year";
        return "Older";
    }
}
