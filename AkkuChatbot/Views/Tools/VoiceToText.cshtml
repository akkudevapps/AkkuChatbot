@{
    ViewData["Title"] = "Voice to Text";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width:700px">
    <h4 class="mb-4">🎤 Voice to Text</h4>
    
    <div class="alert alert-info">
        <strong>Feature Coming Soon!</strong> Real-time voice recognition in 11+ languages.
        <br><small>Tamil, English, Hindi, Telugu, Malayalam, Kannada, and more.</small>
    </div>

    <div class="card bg-dark border-secondary">
        <div class="card-body text-center py-5">
            <i class="fa fa-microphone fa-3x mb-3 text-muted"></i>
            <p class="text-muted">Tap → Speak → Text appears in real-time</p>
            <button class="btn btn-outline-secondary" disabled>
                <i class="fa fa-microphone"></i> Start Recording
            </button>
        </div>
    </div>

    <div class="mt-3">
        <a href="/" class="btn btn-secondary">← Back to Home</a>
        <a href="/Chat" class="btn btn-primary">Go to Chat</a>
    </div>
</div>
