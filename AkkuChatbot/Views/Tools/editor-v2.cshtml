            <button class="sec-btn" onclick="applyTextEffect('glow')"><i class="fa fa-star me-1"></i>Glow</button>
            <button class="sec-btn" onclick="applyTextEffect('outline')"><i class="fa fa-circle-dot me-1"></i>Outline</button>
            <button class="sec-btn" onclick="applyTextEffect('neon')"><i class="fa fa-bolt me-1"></i>Neon</button>
            <button class="sec-btn" onclick="applyTextEffect('retro')"><i class="fa fa-film me-1"></i>Retro 3D</button>
            <button class="sec-btn" onclick="applyTextEffect('curved')"><i class="fa fa-circle-notch me-1"></i>Curved</button>
            <button class="sec-btn" onclick="applyTextEffect('gradient')"><i class="fa fa-fill-drip me-1"></i>Gradient</button>
            <button class="sec-btn err" onclick="removeTextEffect()"><i class="fa fa-xmark me-1"></i>Reset FX</button>
          </div>
          <!-- Effect params -->
          <div style="margin-top:6px;padding:6px;background:var(--bg3);border-radius:4px;border:1px solid var(--bdr)">
            <div class="filter-row"><span class="filter-lbl">Shadow X</span><input type="range" class="filter-slider" id="fxShadowX" min="-20" max="20" value="4" oninput="liveTextFx()"><span class="filter-val" id="fxShadowXV">4</span></div>
            <div class="filter-row"><span class="filter-lbl">Shadow Y</span><input type="range" class="filter-slider" id="fxShadowY" min="-20" max="20" value="4" oninput="liveTextFx()"><span class="filter-val" id="fxShadowYV">4</span></div>
            <div class="filter-row"><span class="filter-lbl">Shadow Blur</span><input type="range" class="filter-slider" id="fxShadowBlur" min="0" max="30" value="5" oninput="liveTextFx()"><span class="filter-val" id="fxShadowBlurV">5</span></div>
            <div class="filter-row">
              <span class="filter-lbl">Shadow Color</span>
              <input type="color" class="colorpick" id="fxShadowColor" value="#000000" oninput="liveTextFx()">
            </div>
          </div>
        </div>
      </div>
    </div>

  </aside>

  <!-- ════ CANVAS AREA ═════════════════════════════════════ -->
  <main class="canvas-area" id="canvasArea">

    <!-- Rulers -->
    <div class="canvas-ruler-row">
      <div class="canvas-ruler-corner"></div>
      <div class="canvas-ruler-h" id="rulerHWrap"><canvas id="rulerH"></canvas></div>
    </div>
    <div class="canvas-main-row" style="flex:1;min-height:0;display:flex">
      <div class="canvas-ruler-v" id="rulerVWrap"><canvas id="rulerV"></canvas></div>

      <div class="canvas-scroll-wrap" id="canvasScrollWrap">
        <!-- Loading overlay -->
        <div class="canvas-overlay" id="canvasOverlay" style="display:none">
          <div class="spin"></div>
          <span style="font-size:12px;color:var(--txt2)" id="overlayMsg">Processing…</span>
          <div class="batch-progress" style="width:200px" id="overlayProgress" style="display:none">
            <div class="batch-prog-bar" id="overlayProgBar"></div>
          </div>
        </div>

        <!-- Inpainting toolbar (shown when inpaint tool active) -->
        <div class="inp-toolbar" id="inpaintToolbar" style="display:none">
          <span style="font-size:10px;color:var(--txt2)">Mask:</span>
          <button class="ob-btn active" id="inpBrushBtn" onclick="setInpaintMode('brush')"><i class="fa fa-paintbrush"></i> Brush</button>
          <button class="ob-btn" id="inpEraseBtn" onclick="setInpaintMode('erase')"><i class="fa fa-eraser"></i> Erase</button>
          <div class="ob-sep"></div>
          <span class="ob-lbl">Size</span>
          <input type="range" id="inpBrushSize" min="5" max="100" value="30" style="width:70px;accent-color:var(--acc)">
          <div class="ob-sep"></div>
          <input type="text" class="ob-input" id="inpPrompt" placeholder="What to paint…" style="width:160px">
          <button class="ob-btn active" onclick="runInpainting()" style="background:var(--acc);color:#fff;border-color:var(--acc)">
            <i class="fa fa-wand-magic-sparkles"></i> Apply ⬡5
          </button>
          <button class="ob-btn err" onclick="setTool('select')"><i class="fa fa-times"></i> Exit</button>
        </div>

        <!-- Crop overlay -->
        <div class="crop-overlay" id="cropOverlay"></div>
        <div class="crop-selection" id="cropSelection" style="display:none"></div>

        <!-- The Fabric.js canvas -->
        <div class="canvas-container-wrapper" id="canvasWrapper">
          <canvas id="editorCanvas"></canvas>
        </div>
      </div>
    </div>

    <!-- Color Palette Strip -->
    <div class="palette-strip" id="paletteStrip">
      <!-- Injected by JS -->
    </div>

    <!-- Status Bar -->
    <div class="status-bar">
      <span id="stCanvas">1024 × 1024</span>
      <div class="sb-sep"></div>
      <span id="stTool">Select</span>
      <div class="sb-sep"></div>
      <span id="stPos">x: — y: —</span>
      <div class="sb-sep"></div>
      <span id="stSel">No selection</span>
      <div class="sb-sep"></div>
      <span id="stObjs">0 obj</span>
      <div class="sb-sep"></div>
      <span id="stHist">H:0/0</span>
      <div class="sb-sep"></div>
      <div class="sb-zoom">
        <button onclick="zoomCanvas(-.25)" style="background:transparent;border:none;color:var(--txt3);font-size:10px;padding:0 2px">−</button>
        <input type="number" id="zoomInput" value="100" min="5" max="3200" onchange="zoomTo(+this.value)" style="">
        <span style="font-size:10px;color:var(--txt3)">%</span>
        <button onclick="zoomCanvas(.25)" style="background:transparent;border:none;color:var(--txt3);font-size:10px;padding:0 2px">+</button>
      </div>
      <button onclick="zoomFit()" style="background:transparent;border:none;color:var(--txt3);font-size:10px;padding:0 4px" title="Fit to screen">Fit</button>
    </div>
  </main>

  <!-- ════ PAGE PANEL ══════════════════════════════════════ -->
  <aside class="page-panel" id="pagePanel">
    <div class="pp-header">
      <span class="pp-title">Pages</span>
      <div class="pp-actions">
        <button class="pp-btn" onclick="addPage()" title="Add page"><i class="fa fa-plus"></i></button>
        <button class="pp-btn" onclick="duplicatePage()" title="Duplicate page"><i class="fa fa-clone"></i></button>
        <button class="pp-btn danger" onclick="deletePage()" title="Delete page"><i class="fa fa-trash"></i></button>
      </div>
    </div>
    <div class="page-list" id="pageList">
      <!-- Thumbnails injected by JS -->
    </div>
    <div class="pp-footer">
      <span class="pp-page-info" id="pageInfo">1 / 1</span>
      <button class="pp-btn" onclick="reorderPagesModal()" title="Reorder"><i class="fa fa-sort"></i></button>
    </div>
    <!-- Canvas size per-page -->
    <div style="padding:5px 6px;border-top:1px solid var(--bdr);font-size:10px">
      <div style="color:var(--txt3);margin-bottom:3px">Canvas Size</div>
      <select class="finp" id="canvasSizePreset" style="height:22px;font-size:10px" onchange="applyCanvasSizePreset(this.value)">
        <option value="">Custom…</option>
        <optgroup label="Screen">
          <option value="1920x1080">1080p HD</option>
          <option value="2560x1440">1440p QHD</option>
          <option value="3840x2160">4K UHD</option>
          <option value="1280x720">720p</option>
          <option value="1024x768">SVGA</option>
        </optgroup>
        <optgroup label="Print (300dpi)">
          <option value="2480x3508">A4 Portrait</option>
          <option value="3508x2480">A4 Landscape</option>
          <option value="1748x2480">A5 Portrait</option>
          <option value="2550x3300">Letter</option>
          <option value="3300x2550">Letter Land</option>
        </optgroup>
        <optgroup label="Social">
          <option value="1080x1080">Square 1080</option>
          <option value="1080x1350">Instagram</option>
          <option value="1080x1920">Story/Reel</option>
          <option value="1200x628">FB/OG Banner</option>
          <option value="1500x500">Twitter Header</option>
          <option value="2560x1440">YouTube Art</option>
        </optgroup>
      </select>
      <div style="display:flex;gap:3px;margin-top:3px">
        <input type="number" class="finp" id="canvasW" value="1024" min="1" max="8000" style="height:22px;font-size:10px" placeholder="W">
        <input type="number" class="finp" id="canvasH" value="1024" min="1" max="8000" style="height:22px;font-size:10px" placeholder="H">
        <button class="sec-btn" onclick="applyCustomCanvasSize()" style="flex-shrink:0;padding:0 6px;height:22px">OK</button>
      </div>
    </div>
  </aside>

  <!-- ════ RIGHT PANEL (Layers + Properties) ═══════════════ -->
  <aside class="right-panel" id="rightPanel">
    <div class="rp-tabs">
      <button class="rp-tab active" onclick="switchRTab('layers')" id="rtLayers">⬛ Layers</button>
      <button class="rp-tab" onclick="switchRTab('shapes')" id="rtShapes">Shapes</button>
      <button class="rp-tab" onclick="switchRTab('history')" id="rtHistory">Hist</button>
    </div>

    <!-- Layers Pane -->
    <div class="rp-pane" id="rpLayers">
      <!-- Blend mode + opacity for selected layer -->
      <div class="opacity-row" style="border-bottom:1px solid var(--bdr);padding:4px 8px">
        <span class="opacity-label" style="min-width:30px">Blend</span>
        <select class="blend-select" id="layerBlend" onchange="setLayerBlend(this.value)">
          <option value="source-over">Normal</option>
          <option value="multiply">Multiply</option>
          <option value="screen">Screen</option>
          <option value="overlay">Overlay</option>
          <option value="darken">Darken</option>
          <option value="lighten">Lighten</option>
          <option value="color-dodge">Color Dodge</option>
          <option value="color-burn">Color Burn</option>
          <option value="soft-light">Soft Light</option>
          <option value="hard-light">Hard Light</option>
          <option value="difference">Difference</option>
          <option value="exclusion">Exclusion</option>
        </select>
      </div>
      <div class="opacity-row" style="border-bottom:1px solid var(--bdr)">
        <span class="opacity-label">Opacity</span>
        <input type="range" class="opacity-slider" id="layerOpacity" min="0" max="1" step="0.01"
          oninput="setLayerOpacity(+this.value);document.getElementById('layerOpVal').textContent=Math.round(this.value*100)+'%'">
        <span class="opacity-val" id="layerOpVal">100%</span>
      </div>

      <!-- Layer action buttons -->
      <div class="layer-header">
        <button class="layer-hbtn" onclick="addLayer()" title="New Layer"><i class="fa fa-plus"></i></button>
        <button class="layer-hbtn" onclick="duplicateLayer()" title="Duplicate"><i class="fa fa-clone"></i></button>
        <button class="layer-hbtn" onclick="groupSelected()" title="Group"><i class="fa fa-object-group"></i></button>
        <button class="layer-hbtn" onclick="mergeDown()" title="Merge Down"><i class="fa fa-compress"></i></button>
        <div style="flex:1"></div>
        <button class="layer-hbtn err" onclick="deleteSelected()" title="Delete"><i class="fa fa-trash"></i></button>
      </div>

      <!-- Layer list -->
      <div id="layersList" style="flex:1;overflow-y:auto">
        <div style="padding:14px 10px;text-align:center;font-size:11px;color:var(--txt3)">Canvas is empty</div>
      </div>
    </div>

    <!-- Shapes Library Pane -->
    <div class="rp-pane" id="rpShapes" style="display:none">
      <div style="padding:8px">
        <div class="ps-label">Basic Shapes</div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:10px">
          <button class="sec-btn" onclick="addShape('rect')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-square" style="font-size:16px"></i>Rect</button>
          <button class="sec-btn" onclick="addShape('rounded')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-square" style="font-size:16px;border-radius:4px"></i>Round</button>
          <button class="sec-btn" onclick="addShape('circle')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-circle" style="font-size:16px"></i>Circle</button>
          <button class="sec-btn" onclick="addShape('ellipse')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-circle" style="font-size:14px;transform:scaleX(.6)"></i>Ellipse</button>
          <button class="sec-btn" onclick="addShape('triangle')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-play" style="font-size:14px;transform:rotate(-90deg)"></i>Triangle</button>
          <button class="sec-btn" onclick="addShape('star')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-star" style="font-size:16px"></i>Star</button>
          <button class="sec-btn" onclick="addShape('line')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-minus" style="font-size:16px"></i>Line</button>
          <button class="sec-btn" onclick="addShape('arrow')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-arrow-right" style="font-size:16px"></i>Arrow</button>
          <button class="sec-btn" onclick="addShape('heart')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-heart" style="font-size:16px"></i>Heart</button>
          <button class="sec-btn" onclick="addShape('diamond')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-diamond" style="font-size:14px"></i>Diamond</button>
          <button class="sec-btn" onclick="addShape('polygon')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-hexagon" style="font-size:14px"></i>Hex</button>
          <button class="sec-btn" onclick="addShape('speech')" style="flex-direction:column;gap:2px;height:44px;font-size:10px"><i class="fa fa-comment" style="font-size:14px"></i>Speech</button>
        </div>

        <div class="ps-label">Stickers</div>
        <div class="sticker-grid" id="stickerGrid"></div>

        <div class="ps-label" style="margin-top:8px">Frames</div>
        <div class="frame-grid" id="frameGrid"></div>
      </div>
    </div>

    <!-- History Pane -->
    <div class="rp-pane" id="rpHistory" style="display:none">
      <div style="padding:6px 8px;border-bottom:1px solid var(--bdr);display:flex;gap:4px;flex-shrink:0">
        <button class="layer-hbtn" onclick="histUndo()"><i class="fa fa-rotate-left"></i> Undo</button>
        <button class="layer-hbtn" onclick="histRedo()"><i class="fa fa-rotate-right"></i> Redo</button>
        <div style="flex:1"></div>
        <button class="layer-hbtn err" onclick="histClear()"><i class="fa fa-trash"></i> Clear</button>
      </div>
      <div id="historyList" style="flex:1;overflow-y:auto">
        <div style="padding:14px;text-align:center;font-size:11px;color:var(--txt3)">No history yet</div>
      </div>
    </div>
  </aside>

</div><!-- /app-shell -->

<!-- ═══════════════════════════════════════════════════════
     MODALS
     ═══════════════════════════════════════════════════════ -->

<!-- EXPORT MODAL -->
<div class="modal-back" id="exportModal" style="display:none" onclick="if(event.target===this)closeModal('exportModal')">
  <div class="modal-box">
    <div class="modal-hdr">
      <span class="modal-title"><i class="fa fa-file-export me-2" style="color:var(--acc)"></i>Export As</span>
      <button class="modal-close" onclick="closeModal('exportModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="ps-label">Format</div>
      <div class="export-format-grid" id="exportFormatGrid">
        <!-- Injected by JS -->
      </div>
      <div style="margin-top:12px" id="exportOptions">
        <div class="row2">
          <div class="form-row">
            <label class="flbl">Quality (JPEG/WebP)</label>
            <input type="range" class="finp" id="exportQuality" min="0.1" max="1" step="0.05" value="0.92" style="height:24px;padding:6px 0">
          </div>
          <div class="form-row">
            <label class="flbl">Scale</label>
            <select class="finp" id="exportScale">
              <option value="1">1× (Original)</option>
              <option value="2">2× (Double)</option>
              <option value="0.5">0.5× (Half)</option>
              <option value="0.75">0.75×</option>
              <option value="3">3×</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <label class="flbl">Which pages to export</label>
          <select class="finp" id="exportPages">
            <option value="current">Current page only</option>
            <option value="all">All pages (ZIP)</option>
            <option value="range">Page range…</option>
          </select>
        </div>
        <div class="form-row" id="exportRangeRow" style="display:none">
          <label class="flbl">Page Range (e.g. 1-3,5)</label>
          <input type="text" class="finp" id="exportPageRange" placeholder="1-3,5,7">
        </div>
        <div class="form-row">
          <label class="flbl">Filename</label>
          <input type="text" class="finp" id="exportFilename" value="artwork" placeholder="filename (no extension)">
        </div>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="modal-ghost-btn" onclick="closeModal('exportModal')">Cancel</button>
      <button class="modal-pri-btn" onclick="doExport()"><i class="fa fa-download me-1"></i>Export</button>
    </div>
  </div>
</div>

<!-- BATCH PROCESSING MODAL -->
<div class="modal-back" id="batchModal" style="display:none" onclick="if(event.target===this)closeModal('batchModal')">
  <div class="modal-box lg">
    <div class="modal-hdr">
      <span class="modal-title"><i class="fa fa-layer-group me-2" style="color:var(--acc)"></i>Batch Processing</span>
      <button class="modal-close" onclick="closeModal('batchModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <!-- Drop zone -->
      <div class="batch-drop" id="batchDrop" onclick="document.getElementById('batchFileInput').click()"
           ondragover="event.preventDefault();this.classList.add('drag-over')"
           ondragleave="this.classList.remove('drag-over')"
           ondrop="handleBatchDrop(event)">
        <i class="fa fa-cloud-arrow-up"></i>
        <p>Drop images here or click to browse</p>
        <p style="font-size:10px;color:var(--txt3);margin-top:4px">Supports: JPG, PNG, WebP, GIF, BMP, TIFF, SVG</p>
      </div>

      <!-- File list -->
      <div class="batch-file-list" id="batchFileList" style="display:none">
        <!-- Injected by JS -->
      </div>

      <!-- Operations -->
      <div class="ps-label">Select Operation</div>
      <div class="batch-op-grid" id="batchOpGrid">
        <div class="batch-op-card sel" data-op="crop" onclick="selectBatchOp('crop')">
          <i class="fa fa-crop-simple"></i>
          <div class="batch-op-title">Batch Crop</div>
          <div class="batch-op-desc">Crop all images to a specific size or aspect ratio</div>
        </div>
        <div class="batch-op-card" data-op="resize" onclick="selectBatchOp('resize')">
          <i class="fa fa-expand-arrows-alt"></i>
          <div class="batch-op-title">Batch Resize</div>
          <div class="batch-op-desc">Resize all images to specific dimensions</div>
        </div>
        <div class="batch-op-card" data-op="bgremove" onclick="selectBatchOp('bgremove')">
          <i class="fa fa-wand-magic-sparkles"></i>
          <div class="batch-op-title">Batch BG Remove <small style="color:var(--coin)">⬡2/img</small></div>
          <div class="batch-op-desc">Remove background from all images using AI</div>
        </div>
        <div class="batch-op-card" data-op="convert" onclick="selectBatchOp('convert')">
          <i class="fa fa-file-image"></i>
          <div class="batch-op-title">Batch Convert</div>
          <div class="batch-op-desc">Convert images to different format (PNG, JPG, WebP…)</div>
        </div>
        <div class="batch-op-card" data-op="filter" onclick="selectBatchOp('filter')">
          <i class="fa fa-palette"></i>
          <div class="batch-op-title">Batch Filter</div>
          <div class="batch-op-desc">Apply filter/adjustment to all images</div>
        </div>
        <div class="batch-op-card" data-op="watermark" onclick="selectBatchOp('watermark')">
          <i class="fa fa-copyright"></i>
          <div class="batch-op-title">Batch Watermark</div>
          <div class="batch-op-desc">Add text or image watermark to all files</div>
        </div>
      </div>

      <!-- Op-specific settings -->
      <div id="batchOpSettings" style="background:var(--bg3);border-radius:6px;padding:10px;border:1px solid var(--bdr)">
        <!-- Crop settings (default) -->
        <div id="bos-crop">
          <div class="row3">
            <div class="form-row">
              <label class="flbl">Crop Width</label>
              <input type="number" class="finp" id="batchCropW" value="800" min="1">
            </div>
            <div class="form-row">
              <label class="flbl">Crop Height</label>
              <input type="number" class="finp" id="batchCropH" value="600" min="1">
            </div>
            <div class="form-row">
              <label class="flbl">Anchor Point</label>
              <select class="finp" id="batchCropAnchor">
                <option value="center">Center</option>
                <option value="top-left">Top-Left</option>
                <option value="top-right">Top-Right</option>
                <option value="bottom-left">Bottom-Left</option>
                <option value="bottom-right">Bottom-Right</option>
                <option value="top">Top Center</option>
                <option value="bottom">Bottom Center</option>
              </select>
            </div>
          </div>
          <div class="row2">
            <div class="form-row">
              <label class="flbl">Aspect Ratio (optional)</label>
              <select class="finp" id="batchCropRatio">
                <option value="">Free / Custom size</option>
                <option value="1:1">1:1 Square</option>
                <option value="16:9">16:9 Widescreen</option>
                <option value="9:16">9:16 Portrait</option>
                <option value="4:3">4:3</option>
                <option value="3:2">3:2</option>
                <option value="2:3">2:3</option>
              </select>
            </div>
            <div class="form-row">
              <label class="flbl">Output Format</label>
              <select class="finp" id="batchCropFmt">
                <option value="png">PNG</option>
                <option value="jpeg">JPEG</option>
                <option value="webp">WebP</option>
              </select>
            </div>
          </div>
        </div>
        <div id="bos-resize" style="display:none">
          <div class="row3">
            <div class="form-row"><label class="flbl">Width (px)</label><input type="number" class="finp" id="batchResW" value="1920" min="1"></div>
            <div class="form-row"><label class="flbl">Height (px)</label><input type="number" class="finp" id="batchResH" value="1080" min="1"></div>
            <div class="form-row"><label class="flbl">Keep Ratio</label><select class="finp" id="batchResRatio"><option value="yes">Yes</option><option value="no">No</option></select></div>
          </div>
        </div>
        <div id="bos-bgremove" style="display:none">
          <p style="font-size:11px;color:var(--txt2)">AI will remove background from each image.<br>Cost: <span style="color:var(--coin)">⬡2 per image</span>. Results download as PNG with transparency.</p>
        </div>
        <div id="bos-convert" style="display:none">
          <div class="row2">
            <div class="form-row"><label class="flbl">Output Format</label>
              <select class="finp" id="batchConvFmt">
                <option value="png">PNG</option><option value="jpeg">JPEG</option>
                <option value="webp">WebP</option><option value="gif">GIF</option>
              </select>
            </div>
            <div class="form-row"><label class="flbl">Quality (JPEG/WebP)</label>
              <input type="range" class="finp" id="batchConvQ" min="0.1" max="1" step="0.05" value="0.9" style="height:24px;padding:6px 0">
            </div>
          </div>
        </div>
        <div id="bos-filter" style="display:none">
          <div class="row3">
            <div class="form-row"><label class="flbl">Filter</label>
              <select class="finp" id="batchFilterType">
                <option value="grayscale">Grayscale (B&W)</option>
                <option value="sepia">Sepia</option>
                <option value="invert">Invert</option>
                <option value="brightness">Brightness</option>
                <option value="contrast">Contrast</option>
                <option value="blur">Blur</option>
              </select>
            </div>
            <div class="form-row"><label class="flbl">Intensity</label><input type="range" class="finp" id="batchFilterVal" min="0" max="100" value="50" style="height:24px;padding:6px 0"></div>
            <div class="form-row"><label class="flbl">Output Format</label>
              <select class="finp" id="batchFilterFmt"><option value="png">PNG</option><option value="jpeg">JPEG</option><option value="webp">WebP</option></select>
            </div>
          </div>
        </div>
        <div id="bos-watermark" style="display:none">
          <div class="row2">
            <div class="form-row"><label class="flbl">Watermark Text</label><input type="text" class="finp" id="batchWmText" value="© AkkuChatbot" placeholder="Your watermark text"></div>
            <div class="form-row"><label class="flbl">Position</label>
              <select class="finp" id="batchWmPos">
                <option value="bottom-right">Bottom Right</option>
                <option value="bottom-left">Bottom Left</option>
                <option value="top-right">Top Right</option>
                <option value="top-left">Top Left</option>
                <option value="center">Center</option>
              </select>
            </div>
          </div>
          <div class="row2">
            <div class="form-row"><label class="flbl">Font Size</label><input type="number" class="finp" id="batchWmSize" value="24" min="8" max="200"></div>
            <div class="form-row"><label class="flbl">Color + Opacity</label>
              <div style="display:flex;gap:4px;align-items:center">
                <input type="color" class="colorpick" id="batchWmColor" value="#ffffff" style="width:34px;height:26px">
                <input type="range" style="flex:1;accent-color:var(--acc)" id="batchWmOpacity" min="0.1" max="1" step="0.05" value="0.7">
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Progress -->
      <div id="batchProgressWrap" style="display:none;margin-top:10px">
        <div style="font-size:11px;color:var(--txt2);margin-bottom:4px" id="batchProgressMsg">Processing 0 / 0…</div>
        <div class="batch-progress"><div class="batch-prog-bar" id="batchProgBar"></div></div>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="modal-ghost-btn" onclick="closeModal('batchModal')">Cancel</button>
      <button class="modal-pri-btn" id="batchRunBtn" onclick="runBatchProcess()">
        <i class="fa fa-play me-1"></i>Run Batch
      </button>
    </div>
  </div>
</div>

<!-- COLLAGE BUILDER MODAL -->
<div class="modal-back" id="collageModal" style="display:none" onclick="if(event.target===this)closeModal('collageModal')">
  <div class="modal-box">
    <div class="modal-hdr">
      <span class="modal-title"><i class="fa fa-table-cells me-2" style="color:var(--acc)"></i>Collage Builder</span>
      <button class="modal-close" onclick="closeModal('collageModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="ps-label">Layout</div>
      <div class="collage-grid" id="collageLayoutGrid"></div>
      <div class="row2">
        <div class="form-row"><label class="flbl">Canvas Size</label>
          <select class="finp" id="collageSize">
            <option value="1080x1080">1080×1080 (Square)</option>
            <option value="1920x1080">1920×1080 (Wide)</option>
            <option value="1080x1920">1080×1920 (Portrait)</option>
            <option value="2480x3508">A4 Portrait</option>
          </select>
        </div>
        <div class="form-row"><label class="flbl">Gap (px)</label>
          <input type="number" class="finp" id="collageGap" value="8" min="0" max="50">
        </div>
      </div>
      <div class="form-row"><label class="flbl">Background Color</label>
        <input type="color" class="finp" id="collageBg" value="#000000" style="height:26px;padding:2px">
      </div>
      <button class="pri-btn" onclick="buildCollage()"><i class="fa fa-table-cells me-1"></i>Build Collage</button>
    </div>
    <div class="modal-ftr">
      <button class="modal-ghost-btn" onclick="closeModal('collageModal')">Close</button>
    </div>
  </div>
</div>

<!-- SAVE ARTWORK MODAL -->
<div class="modal-back" id="saveModal" style="display:none" onclick="if(event.target===this)closeModal('saveModal')">
  <div class="modal-box sm">
    <div class="modal-hdr">
      <span class="modal-title"><i class="fa fa-floppy-disk me-2" style="color:var(--ok)"></i>Save Artwork</span>
      <button class="modal-close" onclick="closeModal('saveModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <label class="flbl">Artwork Name</label>
        <input type="text" class="finp" id="saveTitle" placeholder="My Artwork" maxlength="100">
      </div>
      <div id="saveMsg" style="font-size:11px;color:var(--txt3);margin-top:6px"></div>
    </div>
    <div class="modal-ftr">
      <button class="modal-ghost-btn" onclick="closeModal('saveModal')">Cancel</button>
      <button class="modal-pri-btn" onclick="doSaveArtwork()"><i class="fa fa-floppy-disk me-1"></i>Save</button>
    </div>
  </div>
</div>

<!-- LOAD ARTWORK MODAL -->
<div class="modal-back" id="loadModal" style="display:none" onclick="if(event.target===this)closeModal('loadModal')">
  <div class="modal-box">
    <div class="modal-hdr">
      <span class="modal-title"><i class="fa fa-folder-open me-2" style="color:var(--acc)"></i>My Saved Artworks</span>
      <button class="modal-close" onclick="closeModal('loadModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="art-grid" id="artGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:8px">
        <div style="padding:20px;text-align:center;font-size:11px;color:var(--txt3);grid-column:1/-1">Loading…</div>
      </div>
    </div>
  </div>
</div>

<!-- NEW DOCUMENT MODAL -->
<div class="modal-back" id="newDocModal" style="display:none" onclick="if(event.target===this)closeModal('newDocModal')">
  <div class="modal-box sm">
    <div class="modal-hdr">
      <span class="modal-title"><i class="fa fa-file me-2" style="color:var(--acc)"></i>New Document</span>
      <button class="modal-close" onclick="closeModal('newDocModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="form-row">
        <label class="flbl">Preset</label>
        <select class="finp" id="newDocPreset" onchange="applyNewDocPreset(this.value)">
          <option value="">Custom</option>
          <option value="1920x1080">1920×1080 HD</option>
          <option value="3840x2160">3840×2160 4K</option>
          <option value="1080x1080">1080×1080 Square</option>
          <option value="2480x3508">A4 Portrait (300dpi)</option>
          <option value="1024x1024">1024×1024</option>
        </select>
      </div>
      <div class="row2">
        <div class="form-row"><label class="flbl">Width (px)</label><input type="number" class="finp" id="newDocW" value="1024" min="1" max="8000"></div>
        <div class="form-row"><label class="flbl">Height (px)</label><input type="number" class="finp" id="newDocH" value="1024" min="1" max="8000"></div>
      </div>
      <div class="form-row">
        <label class="flbl">Background</label>
        <div style="display:flex;gap:6px;align-items:center">
          <input type="color" class="colorpick" id="newDocBg" value="#ffffff" style="width:34px;height:26px">
          <button class="sec-btn" onclick="document.getElementById('newDocBg').value='#000000'" >Black</button>
          <button class="sec-btn" onclick="document.getElementById('newDocBg').value='#ffffff'">White</button>
          <button class="sec-btn" onclick="document.getElementById('newDocBg').value='transparent'">Transparent</button>
        </div>
      </div>
    </div>
    <div class="modal-ftr">
      <button class="modal-ghost-btn" onclick="closeModal('newDocModal')">Cancel</button>
      <button class="modal-pri-btn" onclick="createNewDocument()"><i class="fa fa-file me-1"></i>Create</button>
    </div>
  </div>
</div>

<!-- FG/BG COLOR PICKER -->
<div class="modal-back" id="fgBgModal" style="display:none" onclick="if(event.target===this)closeModal('fgBgModal')">
  <div class="modal-box sm">
    <div class="modal-hdr">
      <span class="modal-title">Foreground / Background Color</span>
      <button class="modal-close" onclick="closeModal('fgBgModal')"><i class="fa fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div class="row2">
        <div class="form-row">
          <label class="flbl">Foreground</label>
          <input type="color" class="finp" id="fgColorPick" value="#5d7cf8" oninput="setFgColor(this.value)" style="height:40px;padding:2px">
        </div>
        <div class="form-row">
          <label class="flbl">Background</label>
          <input type="color" class="finp" id="bgColorPick" value="#000000" oninput="setBgColor(this.value)" style="height:40px;padding:2px">
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Toast dock -->
<div class="toast-dock" id="toastDock"></div>

@Html.AntiForgeryToken()
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<!-- Load the main V2 JS -->
<script src="~/js/editor-v2/core.js"></script>
<script src="~/js/editor-v2/tools.js"></script>
<script src="~/js/editor-v2/layers.js"></script>
<script src="~/js/editor-v2/pages.js"></script>
<script src="~/js/editor-v2/ai.js"></script>
<script src="~/js/editor-v2/batch.js"></script>
<script src="~/js/editor-v2/export.js"></script>
<script src="~/js/editor-v2/filters.js"></script>
<script src="~/js/editor-v2/text-effects.js"></script>
<script src="~/js/editor-v2/stickers.js"></script>
<script src="~/js/editor-v2/collage.js"></script>
</body>
</html>
