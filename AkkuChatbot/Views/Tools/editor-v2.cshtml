@{
    ViewData["Title"] = "Image Editor V2";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<title>Image Editor V2 · AkkuChatbot</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
<style>
/* ═══════════════════════════════════════════════════════════
   AKKU EDITOR V2 — PHOTOSHOP-STYLE DESIGN SYSTEM
   ═══════════════════════════════════════════════════════════ */
:root{
  /* Core palette — dark professional */
  --bg:#1a1a1a;--bg2:#222;--bg3:#2a2a2a;--bg4:#333;
  --panel:#252525;--panel2:#2d2d2d;--panel3:#353535;
  --bdr:#3a3a3a;--bdr2:#454545;--bdr3:#555;
  --txt:#e0e0e0;--txt2:#aaa;--txt3:#666;--txt4:#444;
  --acc:#0096ff;--acc2:#0080e0;--acc-dim:rgba(0,150,255,.15);
  --ok:#2ea043;--warn:#d29922;--err:#cf222e;--coin:#e89c35;
  --sel:#0096ff33;
  /* Layout */
  --topbar:36px;--statusbar:20px;--toolw:44px;--lp:260px;--rp:240px;
  --pagepanel:180px;
}
[data-theme="light"]{
  --bg:#f0f0f0;--bg2:#e8e8e8;--bg3:#ddd;--bg4:#ccc;
  --panel:#fff;--panel2:#f5f5f5;--panel3:#ebebeb;
  --bdr:#ccc;--bdr2:#bbb;--bdr3:#999;
  --txt:#1a1a1a;--txt2:#555;--txt3:#888;--txt4:#bbb;
}

/* ── RESET ───────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;user-select:none}
body{font-family:'Inter',system-ui,sans-serif;font-size:12px;
     background:var(--bg);color:var(--txt);line-height:1.4}
button{cursor:pointer;font-family:inherit;border:none;outline:none}
input,select,textarea{font-family:inherit;color:var(--txt);outline:none}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--bdr2);border-radius:3px}
::-webkit-scrollbar-thumb:hover{background:var(--bdr3)}

/* ── TOPBAR ──────────────────────────────────────────────── */
.topbar{
  height:var(--topbar);background:var(--panel);
  border-bottom:1px solid var(--bdr);
  display:flex;align-items:center;gap:0;
  z-index:300;flex-shrink:0;position:relative;
}
.tb-brand{
  display:flex;align-items:center;gap:6px;padding:0 12px;
  border-right:1px solid var(--bdr);height:100%;
  text-decoration:none;color:var(--txt);font-weight:600;font-size:12px;
  white-space:nowrap;flex-shrink:0;
}
.tb-brand-ic{
  width:20px;height:20px;background:var(--acc);
  border-radius:4px;display:flex;align-items:center;justify-content:center;
}
.tb-brand-ic i{color:#fff;font-size:9px}
.tb-menu{display:flex;align-items:center;height:100%;flex-shrink:0}
.tb-menu-btn{
  background:transparent;color:var(--txt2);padding:0 10px;height:100%;
  font-size:11px;font-weight:500;border:none;border-right:none;
  transition:color .1s,background .1s;white-space:nowrap;
}
.tb-menu-btn:hover{background:var(--bg3);color:var(--txt)}
.tb-sep{width:1px;height:18px;background:var(--bdr);margin:0 4px;flex-shrink:0}
.tb-options{display:flex;align-items:center;gap:2px;padding:0 6px;flex:1}
.tb-opt-btn{
  background:transparent;border:1px solid transparent;color:var(--txt2);
  padding:2px 7px;border-radius:3px;font-size:11px;height:24px;
  display:flex;align-items:center;gap:3px;transition:all .1s;white-space:nowrap;
}
.tb-opt-btn:hover{background:var(--bg3);border-color:var(--bdr);color:var(--txt)}
.tb-opt-btn.active{background:var(--acc-dim);border-color:var(--acc);color:var(--acc)}
.tb-opt-btn i{font-size:10px}
.tb-spacer{flex:1}
.coin-badge{
  background:rgba(232,156,53,.1);border:1px solid rgba(232,156,53,.3);
  color:var(--coin);padding:2px 8px;border-radius:12px;
  font-size:10px;font-weight:600;font-family:'JetBrains Mono',monospace;
  white-space:nowrap;margin-right:6px;
}
.tb-user{
  background:transparent;border:none;color:var(--txt2);
  padding:0 10px;height:100%;font-size:11px;
  display:flex;align-items:center;gap:5px;
  border-left:1px solid var(--bdr);
}
.tb-user:hover{background:var(--bg3);color:var(--txt)}

/* ── OPTIONS BAR (context-sensitive, below topbar) ──────── */
.optbar{
  height:30px;background:var(--panel2);border-bottom:1px solid var(--bdr);
  display:flex;align-items:center;padding:0 6px;gap:4px;
  flex-shrink:0;overflow-x:auto;overflow-y:hidden;
}
.optbar::-webkit-scrollbar{height:2px}
.ob-lbl{font-size:9px;color:var(--txt3);white-space:nowrap;padding:0 3px}
.ob-input{
  width:48px;height:20px;background:var(--bg3);border:1px solid var(--bdr);
  color:var(--txt);border-radius:3px;font-size:11px;
  font-family:'JetBrains Mono',monospace;text-align:center;padding:0 2px;
}
.ob-input:focus{border-color:var(--acc)}
.ob-sep{width:1px;height:18px;background:var(--bdr);margin:0 3px;flex-shrink:0}
.ob-select{
  height:20px;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);
  border-radius:3px;font-size:11px;padding:0 3px;
}
.ob-btn{
  background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);
  padding:1px 6px;border-radius:3px;font-size:10px;height:20px;
  display:flex;align-items:center;gap:2px;transition:all .1s;white-space:nowrap;
}
.ob-btn:hover{border-color:var(--acc);color:var(--acc);background:var(--acc-dim)}
.ob-btn.active{background:var(--acc-dim);border-color:var(--acc);color:var(--acc)}
.ob-swatch{
  width:20px;height:20px;border-radius:3px;border:1px solid var(--bdr2);
  cursor:pointer;flex-shrink:0;position:relative;overflow:hidden;
  background:repeating-conic-gradient(#777 0 25%,transparent 0 50%) 0 0 / 6px 6px;
}
.ob-swatch-inner{position:absolute;inset:0}
.ob-color-inp{opacity:0;position:absolute;inset:0;width:100%;height:100%;cursor:pointer;padding:0;border:none}

/* ── APP SHELL ───────────────────────────────────────────── */
.app-shell{display:flex;height:calc(100dvh - var(--topbar) - 30px);overflow:hidden}

/* ── LEFT TOOL SIDEBAR (Photoshop-style narrow icon bar) ── */
.tool-sidebar{
  width:var(--toolw);background:var(--panel);
  border-right:1px solid var(--bdr);
  display:flex;flex-direction:column;align-items:center;
  padding:4px 0;gap:2px;flex-shrink:0;overflow:hidden;
}
.ts-tool{
  width:36px;height:36px;background:transparent;border:1px solid transparent;
  border-radius:5px;color:var(--txt2);font-size:14px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:1px;transition:all .1s;position:relative;flex-shrink:0;
}
.ts-tool:hover{background:var(--bg3);border-color:var(--bdr);color:var(--txt)}
.ts-tool.active{background:var(--acc-dim);border-color:var(--acc);color:var(--acc)}
.ts-tool .tkey{font-size:7px;color:inherit;opacity:.6;font-family:'JetBrains Mono',monospace}
.ts-sep{width:28px;height:1px;background:var(--bdr);margin:2px 0;flex-shrink:0}
.ts-group-arrow{
  position:absolute;bottom:1px;right:2px;font-size:5px;
  color:var(--txt3);pointer-events:none;
}
.ts-spacer{flex:1}
.fg-bg-swatch{
  display:flex;flex-direction:column;align-items:center;gap:0;
  padding:2px;position:relative;cursor:pointer;
}
.fg-swatch,.bg-swatch{
  width:22px;height:22px;border:2px solid var(--bdr3);border-radius:3px;cursor:pointer;
}
.fg-swatch{z-index:2;position:relative}
.bg-swatch{position:absolute;bottom:6px;right:4px;z-index:1;width:18px;height:18px}
.fg-reset{font-size:7px;color:var(--txt3);margin-top:2px;text-align:center}

/* ── LEFT PANEL (Properties / AI Gen) ───────────────────── */
.left-panel{
  width:var(--lp);background:var(--panel);
  border-right:1px solid var(--bdr);
  display:flex;flex-direction:column;flex-shrink:0;
  overflow:hidden;
}
.lp-tabs{display:flex;border-bottom:1px solid var(--bdr);flex-shrink:0}
.lp-tab{
  flex:1;padding:6px 4px;font-size:10px;font-weight:600;text-align:center;
  background:transparent;border:none;color:var(--txt3);
  border-bottom:2px solid transparent;transition:all .12s;
  text-transform:uppercase;letter-spacing:.04em;
}
.lp-tab.active{color:var(--acc);border-bottom-color:var(--acc);background:var(--acc-dim)}
.lp-pane{flex:1;overflow-y:auto;display:flex;flex-direction:column}

/* ── CANVAS AREA ─────────────────────────────────────────── */
.canvas-area{
  flex:1;display:flex;flex-direction:column;min-width:0;
  background:var(--bg2);position:relative;
}
.canvas-ruler-row{display:flex;flex-shrink:0}
.canvas-ruler-corner{width:16px;height:16px;background:var(--panel2);border-right:1px solid var(--bdr);border-bottom:1px solid var(--bdr);flex-shrink:0}
.canvas-ruler-h{flex:1;height:16px;background:var(--panel2);border-bottom:1px solid var(--bdr);overflow:hidden;position:relative}
.canvas-ruler-v{width:16px;background:var(--panel2);border-right:1px solid var(--bdr);flex-shrink:0}
.canvas-main-row{display:flex;flex:1;min-height:0}
.canvas-scroll-wrap{
  flex:1;overflow:auto;position:relative;
  display:flex;align-items:center;justify-content:center;
  background:var(--bg2);
  /* Checker pattern for transparent areas */
  background-image:
    linear-gradient(45deg,var(--bg3) 25%,transparent 25%),
    linear-gradient(-45deg,var(--bg3) 25%,transparent 25%),
    linear-gradient(45deg,transparent 75%,var(--bg3) 75%),
    linear-gradient(-45deg,transparent 75%,var(--bg3) 75%);
  background-size:16px 16px;
  background-position:0 0,0 8px,8px -8px,-8px 0;
}
.canvas-container-wrapper{
  position:relative;
  box-shadow:0 4px 32px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.05);
}
/* Rulers canvas elements */
#rulerH,#rulerV{position:absolute;top:0;left:0;pointer-events:none}

/* ── PAGE PANEL (right of canvas) ────────────────────────── */
.page-panel{
  width:var(--pagepanel);background:var(--panel);
  border-left:1px solid var(--bdr);
  display:flex;flex-direction:column;flex-shrink:0;
  overflow:hidden;
}
.pp-header{
  padding:6px 8px;border-bottom:1px solid var(--bdr);
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;
}
.pp-title{font-size:10px;font-weight:600;color:var(--txt2);text-transform:uppercase;letter-spacing:.05em}
.pp-actions{display:flex;gap:2px}
.pp-btn{
  width:22px;height:22px;background:var(--bg3);border:1px solid var(--bdr);
  border-radius:3px;color:var(--txt2);font-size:10px;
  display:flex;align-items:center;justify-content:center;transition:all .1s;
}
.pp-btn:hover{border-color:var(--acc);color:var(--acc);background:var(--acc-dim)}
.pp-btn.danger:hover{border-color:var(--err);color:var(--err);background:rgba(207,34,46,.1)}
.page-list{flex:1;overflow-y:auto;padding:4px}
.page-thumb{
  border:2px solid var(--bdr);border-radius:5px;margin-bottom:4px;
  cursor:pointer;transition:all .12s;overflow:hidden;
  background:var(--bg3);position:relative;
}
.page-thumb:hover{border-color:var(--bdr2)}
.page-thumb.active{border-color:var(--acc);box-shadow:0 0 0 1px var(--acc)}
.page-thumb canvas{width:100%;display:block}
.page-thumb-label{
  display:flex;align-items:center;justify-content:space-between;
  padding:3px 5px;font-size:9px;color:var(--txt3);
  background:var(--panel);border-top:1px solid var(--bdr);
}
.page-thumb-label span{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.page-menu-btn{background:transparent;border:none;color:var(--txt4);font-size:9px;padding:0 2px;flex-shrink:0}
.page-menu-btn:hover{color:var(--txt)}
.pp-footer{
  padding:5px 6px;border-top:1px solid var(--bdr);
  display:flex;align-items:center;gap:4px;flex-shrink:0;
}
.pp-page-info{font-size:10px;color:var(--txt3);font-family:'JetBrains Mono',monospace;flex:1;text-align:center}

/* ── RIGHT PANEL (Layers / Properties) ───────────────────── */
.right-panel{
  width:var(--rp);background:var(--panel);
  border-left:1px solid var(--bdr);
  display:flex;flex-direction:column;flex-shrink:0;overflow:hidden;
}
.rp-tabs{display:flex;border-bottom:1px solid var(--bdr);flex-shrink:0}
.rp-tab{
  flex:1;padding:5px 2px;font-size:10px;font-weight:600;text-align:center;
  background:transparent;border:none;color:var(--txt3);
  border-bottom:2px solid transparent;transition:all .12s;
  text-transform:uppercase;letter-spacing:.04em;
}
.rp-tab.active{color:var(--acc);border-bottom-color:var(--acc);background:var(--acc-dim)}
.rp-pane{flex:1;overflow-y:auto;display:flex;flex-direction:column}

/* ── STATUS BAR ──────────────────────────────────────────── */
.status-bar{
  height:var(--statusbar);background:var(--panel);
  border-top:1px solid var(--bdr);
  display:flex;align-items:center;padding:0 8px;gap:6px;
  font-size:10px;color:var(--txt3);font-family:'JetBrains Mono',monospace;
  flex-shrink:0;
}
.sb-sep{width:1px;height:12px;background:var(--bdr);margin:0 4px;flex-shrink:0}
.sb-zoom{display:flex;align-items:center;gap:2px}
.sb-zoom input{
  width:44px;height:14px;background:var(--bg3);border:1px solid var(--bdr);
  color:var(--txt);border-radius:2px;font-size:10px;
  font-family:'JetBrains Mono',monospace;text-align:center;padding:0;
}

/* ── COLOR PALETTE STRIP (bottom) ────────────────────────── */
.palette-strip{
  height:24px;background:var(--panel2);border-top:1px solid var(--bdr);
  display:flex;align-items:center;padding:0 4px;gap:1px;
  overflow-x:auto;overflow-y:hidden;flex-shrink:0;
}
.palette-strip::-webkit-scrollbar{height:2px}
.pal-swatch{
  width:18px;height:18px;border-radius:2px;border:1px solid rgba(0,0,0,.4);
  cursor:pointer;flex-shrink:0;transition:transform .08s;
}
.pal-swatch:hover{transform:scale(1.5);z-index:20;box-shadow:0 2px 8px rgba(0,0,0,.7);border-color:var(--txt)}
.pal-sep{width:1px;height:16px;background:var(--bdr);margin:0 2px;flex-shrink:0}

/* ── PANEL INTERNALS ─────────────────────────────────────── */
.panel-section{padding:8px 10px;border-bottom:1px solid var(--bdr)}
.panel-section:last-child{border-bottom:none}
.ps-label{
  font-size:9px;text-transform:uppercase;letter-spacing:.06em;
  color:var(--txt3);font-weight:600;margin-bottom:6px;
  display:flex;align-items:center;justify-content:space-between;
}
.ps-label button{
  font-size:9px;color:var(--txt3);background:transparent;border:none;
  padding:1px 4px;border-radius:2px;
}
.ps-label button:hover{color:var(--txt);background:var(--bg3)}
.form-row{margin-bottom:7px}
.flbl{font-size:10px;color:var(--txt2);margin-bottom:3px;display:block}
.finp{
  width:100%;height:24px;background:var(--bg3);border:1px solid var(--bdr);
  color:var(--txt);border-radius:4px;font-size:11px;padding:0 6px;
  transition:border-color .1s;
}
.finp:focus{border-color:var(--acc)}
.finp::placeholder{color:var(--txt4)}
textarea.finp{height:auto;resize:none;padding:5px 6px;line-height:1.4}
select.finp{cursor:pointer}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px}
.pri-btn{
  width:100%;height:26px;background:var(--acc);color:#fff;border:none;
  border-radius:4px;font-size:12px;font-weight:600;
  display:flex;align-items:center;justify-content:center;gap:5px;
  transition:all .15s;
}
.pri-btn:hover:not(:disabled){background:var(--acc2)}
.pri-btn:disabled{opacity:.45;pointer-events:none}
.pri-btn.warn{background:var(--warn)}
.pri-btn.warn:hover{background:#bb8820}
.sec-btn{
  height:24px;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);
  border-radius:4px;font-size:11px;padding:0 8px;
  display:flex;align-items:center;justify-content:center;gap:4px;transition:all .1s;
}
.sec-btn:hover{border-color:var(--acc);color:var(--acc);background:var(--acc-dim)}
.sec-btn.full{width:100%}
.sec-btn.err:hover{border-color:var(--err);color:var(--err);background:rgba(207,34,46,.1)}

/* ── LAYER PANEL ─────────────────────────────────────────── */
.layer-header{
  padding:5px 8px;border-bottom:1px solid var(--bdr);
  display:flex;align-items:center;gap:3px;flex-shrink:0;
}
.layer-hbtn{
  height:22px;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);
  border-radius:3px;font-size:10px;padding:0 5px;
  display:flex;align-items:center;gap:2px;transition:all .1s;
}
.layer-hbtn:hover{border-color:var(--acc);color:var(--acc);background:var(--acc-dim)}
.layer-hbtn.err:hover{border-color:var(--err);color:var(--err)}
.layer-item{
  display:flex;align-items:center;gap:4px;padding:5px 6px;
  border-bottom:1px solid var(--bdr);cursor:pointer;
  transition:background .1s;min-height:34px;
}
.layer-item:hover{background:var(--bg3)}
.layer-item.sel{background:var(--acc-dim)}
.layer-thumb{
  width:26px;height:26px;border-radius:3px;border:1px solid var(--bdr);
  object-fit:cover;flex-shrink:0;background:var(--bg3);
}
.layer-ic{width:14px;text-align:center;font-size:11px;color:var(--txt2);flex-shrink:0}
.layer-name{flex:1;font-size:11px;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.layer-name-inp{
  flex:1;height:18px;background:var(--bg);border:1px solid var(--acc);
  color:var(--txt);border-radius:2px;font-size:11px;padding:0 3px;
}
.layer-vis,.layer-lock-btn{
  background:transparent;border:none;color:var(--txt3);
  font-size:10px;padding:2px 3px;flex-shrink:0;line-height:1;
}
.layer-vis:hover,.layer-lock-btn:hover{color:var(--txt)}
.blend-select{
  width:100%;height:20px;background:var(--bg3);border:1px solid var(--bdr);
  color:var(--txt);border-radius:3px;font-size:10px;padding:0 3px;
}
.opacity-row{display:flex;align-items:center;gap:5px;padding:5px 8px;flex-shrink:0}
.opacity-label{font-size:10px;color:var(--txt3);white-space:nowrap;min-width:42px}
.opacity-slider{flex:1;accent-color:var(--acc)}
.opacity-val{font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--txt2);min-width:30px;text-align:right}
.fill-row{display:flex;align-items:center;gap:5px;padding:4px 8px;flex-shrink:0;border-bottom:1px solid var(--bdr)}

/* ── PROPERTIES PANEL ────────────────────────────────────── */
.prop-row{
  display:flex;align-items:center;gap:4px;padding:3px 8px;
  border-bottom:1px solid var(--bdr);
}
.prop-lbl{font-size:10px;color:var(--txt3);min-width:32px;white-space:nowrap}
.prop-inp{
  flex:1;height:20px;background:var(--bg3);border:1px solid var(--bdr);
  color:var(--txt);border-radius:3px;font-size:10px;
  font-family:'JetBrains Mono',monospace;padding:0 4px;text-align:right;
}
.prop-inp:focus{border-color:var(--acc)}
.prop-inp:read-only{opacity:.5}
.prop-2col{display:grid;grid-template-columns:1fr 1fr;gap:4px;padding:4px 8px;border-bottom:1px solid var(--bdr)}
.prop-field{display:flex;flex-direction:column;gap:2px}
.prop-fl{font-size:9px;color:var(--txt4)}
.colorpick{
  width:28px;height:20px;border:1px solid var(--bdr);border-radius:3px;
  background:var(--bg3);cursor:pointer;padding:1px;
}
.colorpick::-webkit-color-swatch-wrapper{padding:0;border-radius:2px}

/* ── MODALS ──────────────────────────────────────────────── */
.modal-back{
  position:fixed;inset:0;background:rgba(0,0,0,.75);
  display:flex;align-items:center;justify-content:center;
  z-index:1000;backdrop-filter:blur(3px);
}
.modal-box{
  background:var(--panel);border:1px solid var(--bdr2);border-radius:8px;
  width:90%;max-width:700px;max-height:88dvh;
  display:flex;flex-direction:column;overflow:hidden;
  box-shadow:0 16px 60px rgba(0,0,0,.7);
}
.modal-box.sm{max-width:420px}
.modal-box.lg{max-width:900px}
.modal-hdr{
  display:flex;align-items:center;padding:10px 14px;
  border-bottom:1px solid var(--bdr);gap:8px;flex-shrink:0;
}
.modal-title{font-weight:600;font-size:13px;flex:1}
.modal-close{
  background:transparent;border:none;color:var(--txt2);
  font-size:14px;padding:2px 6px;border-radius:3px;
}
.modal-close:hover{color:var(--txt);background:var(--bg3)}
.modal-body{padding:12px 14px;overflow-y:auto;flex:1}
.modal-ftr{
  padding:8px 14px;border-top:1px solid var(--bdr);
  display:flex;gap:6px;justify-content:flex-end;flex-shrink:0;
}
.modal-pri-btn{
  background:var(--acc);color:#fff;border:none;
  padding:5px 16px;border-radius:4px;font-size:12px;font-weight:600;
  transition:background .1s;
}
.modal-pri-btn:hover{background:var(--acc2)}
.modal-ghost-btn{
  background:transparent;color:var(--txt2);
  border:1px solid var(--bdr);padding:5px 12px;
  border-radius:4px;font-size:12px;transition:all .1s;
}
.modal-ghost-btn:hover{border-color:var(--bdr2);color:var(--txt)}

/* ── BATCH PANEL ─────────────────────────────────────────── */
.batch-drop{
  border:2px dashed var(--bdr2);border-radius:6px;
  padding:24px;text-align:center;cursor:pointer;
  transition:all .15s;margin-bottom:10px;
}
.batch-drop:hover,.batch-drop.drag-over{border-color:var(--acc);background:var(--acc-dim)}
.batch-drop i{font-size:28px;color:var(--txt3);margin-bottom:8px;display:block}
.batch-drop p{font-size:12px;color:var(--txt2)}
.batch-file-list{max-height:220px;overflow-y:auto;border:1px solid var(--bdr);border-radius:5px;margin-bottom:10px}
.bf-item{
  display:flex;align-items:center;gap:6px;padding:5px 8px;
  border-bottom:1px solid var(--bdr);font-size:11px;
}
.bf-item:last-child{border-bottom:none}
.bf-thumb{width:32px;height:32px;object-fit:cover;border-radius:3px;border:1px solid var(--bdr);flex-shrink:0}
.bf-name{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:var(--txt2)}
.bf-size{color:var(--txt3);white-space:nowrap;font-family:'JetBrains Mono',monospace;font-size:10px}
.bf-remove{background:transparent;border:none;color:var(--txt4);font-size:11px;padding:2px 4px}
.bf-remove:hover{color:var(--err)}
.batch-op-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-bottom:10px}
.batch-op-card{
  border:1px solid var(--bdr);border-radius:5px;padding:8px;cursor:pointer;
  transition:all .12s;display:flex;flex-direction:column;gap:3px;
}
.batch-op-card:hover,.batch-op-card.sel{border-color:var(--acc);background:var(--acc-dim)}
.batch-op-card i{font-size:16px;color:var(--txt2)}
.batch-op-card.sel i{color:var(--acc)}
.batch-op-title{font-size:11px;font-weight:600;color:var(--txt)}
.batch-op-desc{font-size:10px;color:var(--txt3)}
.batch-progress{
  background:var(--bg3);border-radius:3px;height:6px;
  overflow:hidden;margin-top:6px;
}
.batch-prog-bar{height:100%;background:var(--acc);border-radius:3px;transition:width .2s;width:0}

/* ── AI PANEL ────────────────────────────────────────────── */
.ai-gen-thumb{
  width:100%;aspect-ratio:1;object-fit:cover;border-radius:5px;
  border:1px solid var(--bdr);cursor:pointer;display:block;margin-bottom:4px;
}
.ai-gen-thumb:hover{border-color:var(--acc)}
.recent-gen-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
.rg-item{width:100%;aspect-ratio:1;object-fit:cover;border-radius:4px;
  border:1px solid var(--bdr);cursor:pointer;transition:all .12s}
.rg-item:hover{border-color:var(--acc);transform:scale(1.04)}

/* ── FILTER SLIDERS ──────────────────────────────────────── */
.filter-row{display:flex;align-items:center;gap:5px;padding:3px 8px}
.filter-lbl{font-size:10px;color:var(--txt3);min-width:58px}
.filter-slider{flex:1;accent-color:var(--acc);height:12px}
.filter-val{font-size:10px;font-family:'JetBrains Mono',monospace;color:var(--txt2);min-width:28px;text-align:right}

/* ── TOAST ───────────────────────────────────────────────── */
.toast-dock{position:fixed;bottom:50px;right:12px;z-index:9999;display:flex;flex-direction:column;gap:4px;pointer-events:none}
.toast-item{
  padding:7px 12px;border-radius:5px;font-size:11px;font-weight:500;
  color:#fff;opacity:0;transform:translateX(12px);
  transition:all .2s ease;pointer-events:auto;max-width:240px;
}
.toast-item.show{opacity:1;transform:translateX(0)}
.t-ok{background:var(--ok)}.t-err{background:var(--err)}
.t-info{background:var(--acc)}.t-warn{background:var(--warn)}

/* ── OVERLAY (Generation loading) ────────────────────────── */
.canvas-overlay{
  position:absolute;inset:0;background:rgba(0,0,0,.7);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  z-index:100;gap:10px;
}
.spin{width:32px;height:32px;border:3px solid var(--bdr);border-top-color:var(--acc);border-radius:50%;animation:spin .7s linear infinite}
@@keyframes spin{to{transform:rotate(360deg)}}

/* ── INPAINTING ──────────────────────────────────────────── */
.inp-toolbar{
  position:absolute;top:8px;left:50%;transform:translateX(-50%);
  background:var(--panel);border:1px solid var(--bdr2);border-radius:6px;
  padding:4px 8px;display:flex;align-items:center;gap:4px;
  z-index:50;box-shadow:0 4px 16px rgba(0,0,0,.5);
}
.inp-mode-toggle{display:none}
.inp-mode-toggle.active{display:flex}

/* ── STICKERS GRID ───────────────────────────────────────── */
.sticker-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:4px}
.sticker-btn{
  font-size:22px;text-align:center;cursor:pointer;
  padding:5px;border-radius:5px;transition:background .1s;border:1px solid transparent;
  background:transparent;
}
.sticker-btn:hover{background:var(--bg3);border-color:var(--bdr)}

/* ── FRAMES ──────────────────────────────────────────────── */
.frame-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.frame-card{
  border:2px solid var(--bdr);border-radius:5px;padding:4px;cursor:pointer;
  transition:all .12s;aspect-ratio:1;display:flex;align-items:center;justify-content:center;
}
.frame-card:hover{border-color:var(--acc)}
.frame-preview{width:100%;height:100%;border-radius:3px;background:var(--bg3)}

/* ── EXPORT PANEL ────────────────────────────────────────── */
.export-format-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:5px}
.export-fmt{
  border:1px solid var(--bdr);border-radius:4px;padding:6px 4px;
  text-align:center;cursor:pointer;transition:all .12s;
}
.export-fmt:hover{border-color:var(--acc);background:var(--acc-dim)}
.export-fmt.sel{border-color:var(--acc);background:var(--acc-dim);color:var(--acc)}
.export-fmt-name{font-size:11px;font-weight:600}
.export-fmt-desc{font-size:9px;color:var(--txt3);margin-top:1px}

/* ── CROP OVERLAY ────────────────────────────────────────── */
.crop-overlay{
  position:absolute;inset:0;z-index:40;
  background:rgba(0,0,0,.0);cursor:crosshair;display:none;
}
.crop-selection{
  position:absolute;border:2px solid var(--acc);
  box-shadow:0 0 0 9999px rgba(0,0,0,.45);pointer-events:none;
}

/* ── TEXT EFFECTS PREVIEW ────────────────────────────────── */
.text-fx-grid{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:6px}
.text-fx-btn{
  background:var(--bg3);border:1px solid var(--bdr);border-radius:4px;
  padding:5px 4px;text-align:center;cursor:pointer;transition:all .1s;font-size:11px;
}
.text-fx-btn:hover{border-color:var(--acc);color:var(--acc);background:var(--acc-dim)}

/* ── COLLAGE LAYOUT GRID ─────────────────────────────────── */
.collage-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;margin-bottom:8px}
.collage-layout{
  border:1px solid var(--bdr);border-radius:4px;cursor:pointer;
  aspect-ratio:1;padding:4px;transition:all .12s;overflow:hidden;
}
.collage-layout:hover,.collage-layout.sel{border-color:var(--acc);background:var(--acc-dim)}
.collage-preview{width:100%;height:100%;display:grid;gap:2px;border-radius:2px;overflow:hidden}
.collage-cell{background:var(--bdr2);border-radius:1px}

/* ── MOBILE ──────────────────────────────────────────────── */
@@media(max-width:900px){
  :root{--lp:100%;--rp:0px;--pagepanel:0px}
  .left-panel{
    position:fixed;bottom:0;left:0;right:0;
    width:100%!important;height:60vh;
    border-top:1px solid var(--bdr);
    z-index:200;display:flex;
    border-radius:12px 12px 0 0;
  }
  .right-panel,.page-panel{display:none}
}
</style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════════
     TOP MENU BAR
     ═══════════════════════════════════════════════════════ -->
<header class="topbar">
  <a href="/" class="tb-brand">
    <div class="tb-brand-ic"><i class="fa fa-robot"></i></div>
    <span>AkkuChatbot</span>
  </a>

  <div class="tb-menu">
    <!-- File Menu -->
    <div class="dropdown">
      <button class="tb-menu-btn dropdown-toggle" data-bs-toggle="dropdown">File</button>
      <ul class="dropdown-menu" style="background:var(--panel);border-color:var(--bdr2);min-width:200px">
        <li><a class="dropdown-item" href="#" onclick="newDocument()" style="color:var(--txt);font-size:12px"><i class="fa fa-file me-2" style="width:14px"></i>New… <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+N</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="openFileDialog()" style="color:var(--txt);font-size:12px"><i class="fa fa-folder-open me-2" style="width:14px"></i>Open… <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+O</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="openLoadModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-cloud me-2" style="width:14px"></i>Open from Cloud</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="saveArtwork()" style="color:var(--txt);font-size:12px"><i class="fa fa-floppy-disk me-2" style="width:14px"></i>Save <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+S</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="saveArtworkAs()" style="color:var(--txt);font-size:12px"><i class="fa fa-floppy-disk me-2" style="width:14px"></i>Save As…</a></li>
        <li><a class="dropdown-item" href="#" onclick="exportProject()" style="color:var(--txt);font-size:12px"><i class="fa fa-file-zipper me-2" style="width:14px"></i>Export Project (.akku)</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="openExportModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-file-export me-2" style="width:14px"></i>Export As… <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+E</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="openBatchModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-layer-group me-2" style="width:14px"></i>Batch Processing…</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="printCanvasPreview()" style="color:var(--txt);font-size:12px"><i class="fa fa-print me-2" style="width:14px"></i>Print… <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+P</span></a></li>
      </ul>
    </div>
    <div class="dropdown">
      <button class="tb-menu-btn dropdown-toggle" data-bs-toggle="dropdown">Edit</button>
      <ul class="dropdown-menu" style="background:var(--panel);border-color:var(--bdr2);min-width:200px">
        <li><a class="dropdown-item" href="#" onclick="histUndo()" style="color:var(--txt);font-size:12px"><i class="fa fa-rotate-left me-2" style="width:14px"></i>Undo <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+Z</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="histRedo()" style="color:var(--txt);font-size:12px"><i class="fa fa-rotate-right me-2" style="width:14px"></i>Redo <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+Y</span></a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="copySelected()" style="color:var(--txt);font-size:12px"><i class="fa fa-copy me-2" style="width:14px"></i>Copy <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+C</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="cutSelected()" style="color:var(--txt);font-size:12px"><i class="fa fa-scissors me-2" style="width:14px"></i>Cut <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+X</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="pasteLocal()" style="color:var(--txt);font-size:12px"><i class="fa fa-paste me-2" style="width:14px"></i>Paste <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+V</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="duplicateSelected()" style="color:var(--txt);font-size:12px"><i class="fa fa-clone me-2" style="width:14px"></i>Duplicate <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+D</span></a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="selectAll()" style="color:var(--txt);font-size:12px"><i class="fa fa-object-group me-2" style="width:14px"></i>Select All <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+A</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="deleteSelected()" style="color:var(--err);font-size:12px"><i class="fa fa-trash me-2" style="width:14px"></i>Delete <span style="float:right;color:var(--txt3);font-size:10px">Del</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="clearCanvas()" style="color:var(--err);font-size:12px"><i class="fa fa-ban me-2" style="width:14px"></i>Clear All</a></li>
      </ul>
    </div>
    <div class="dropdown">
      <button class="tb-menu-btn dropdown-toggle" data-bs-toggle="dropdown">Image</button>
      <ul class="dropdown-menu" style="background:var(--panel);border-color:var(--bdr2);min-width:200px">
        <li><a class="dropdown-item" href="#" onclick="openCanvasSizeModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-expand me-2" style="width:14px"></i>Canvas Size…</a></li>
        <li><a class="dropdown-item" href="#" onclick="openResizeModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-compress-arrows-alt me-2" style="width:14px"></i>Image Size…</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="openCropTool()" style="color:var(--txt);font-size:12px"><i class="fa fa-crop me-2" style="width:14px"></i>Crop</a></li>
        <li><a class="dropdown-item" href="#" onclick="openRotateModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-rotate me-2" style="width:14px"></i>Rotate / Flip…</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="removeBackground()" style="color:var(--txt);font-size:12px"><i class="fa fa-wand-magic-sparkles me-2" style="width:14px"></i>Remove Background <small style="color:var(--coin)">⬡2</small></a></li>
        <li><a class="dropdown-item" href="#" onclick="upscaleImage()" style="color:var(--txt);font-size:12px"><i class="fa fa-up-right-and-down-left-from-center me-2" style="width:14px"></i>Upscale Image <small style="color:var(--coin)">⬡3</small></a></li>
        <li><a class="dropdown-item" href="#" onclick="openInpaintingTool()" style="color:var(--txt);font-size:12px"><i class="fa fa-paintbrush me-2" style="width:14px"></i>AI Inpainting… <small style="color:var(--coin)">⬡5</small></a></li>
      </ul>
    </div>
    <div class="dropdown">
      <button class="tb-menu-btn dropdown-toggle" data-bs-toggle="dropdown">Layer</button>
      <ul class="dropdown-menu" style="background:var(--panel);border-color:var(--bdr2);min-width:200px">
        <li><a class="dropdown-item" href="#" onclick="addLayer()" style="color:var(--txt);font-size:12px"><i class="fa fa-plus me-2" style="width:14px"></i>New Layer</a></li>
        <li><a class="dropdown-item" href="#" onclick="duplicateLayer()" style="color:var(--txt);font-size:12px"><i class="fa fa-clone me-2" style="width:14px"></i>Duplicate Layer</a></li>
        <li><a class="dropdown-item" href="#" onclick="mergeDown()" style="color:var(--txt);font-size:12px"><i class="fa fa-layer-group me-2" style="width:14px"></i>Merge Down</a></li>
        <li><a class="dropdown-item" href="#" onclick="mergeAllLayers()" style="color:var(--txt);font-size:12px"><i class="fa fa-compress me-2" style="width:14px"></i>Flatten Image</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="#" onclick="groupSelected()" style="color:var(--txt);font-size:12px"><i class="fa fa-object-group me-2" style="width:14px"></i>Group Selected <span style="float:right;color:var(--txt3);font-size:10px">Ctrl+G</span></a></li>
        <li><a class="dropdown-item" href="#" onclick="ungroupSelected()" style="color:var(--txt);font-size:12px"><i class="fa fa-object-ungroup me-2" style="width:14px"></i>Ungroup</a></li>
      </ul>
    </div>
    <!-- 🆕 Tools menu -->
        <div class="dropdown">
          <button class="tb-menu-btn dropdown-toggle" data-bs-toggle="dropdown">Tools</button>
          <ul class="dropdown-menu" style="background:var(--panel);border-color:var(--bdr2)">
            <li><a class="dropdown-item" href="/Tools/PromptTemplates" target="_blank"
                   style="color:var(--txt);font-size:12px">
                   <i class="fa fa-layer-group me-2" style="width:14px"></i>
                   Prompt Templates ↗
            </a></li>
            <li><a class="dropdown-item" href="/Chat" target="_blank"
                   style="color:var(--txt);font-size:12px">
                   <i class="fa fa-robot me-2" style="width:14px"></i>
                   AI Chat ↗
            </a></li>
          </ul>
        </div>
    <div class="dropdown">
      <button class="tb-menu-btn dropdown-toggle" data-bs-toggle="dropdown">Tools</button>
      <ul class="dropdown-menu" style="background:var(--panel);border-color:var(--bdr2);min-width:200px">
        <li><a class="dropdown-item" href="#" onclick="openBatchModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-layer-group me-2" style="width:14px"></i>Batch Processing…</a></li>
        <li><a class="dropdown-item" href="#" onclick="openCollageModal()" style="color:var(--txt);font-size:12px"><i class="fa fa-table-cells me-2" style="width:14px"></i>Collage Builder…</a></li>
        <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
        <li><a class="dropdown-item" href="/Tools/ImageToText" target="_blank" style="color:var(--txt);font-size:12px"><i class="fa fa-file-image me-2" style="width:14px"></i>Image to Text</a></li>
        <li><a class="dropdown-item" href="/Tools/PromptTemplates" target="_blank" style="color:var(--txt);font-size:12px"><i class="fa fa-layer-group me-2" style="width:14px"></i>Prompt Templates</a></li>
      </ul>
    </div>
  </div>

  <!-- Options bar right side -->
  <div class="tb-spacer"></div>
  <button class="tb-opt-btn" onclick="histUndo()" id="topUndoBtn" title="Undo Ctrl+Z"><i class="fa fa-rotate-left"></i></button>
  <button class="tb-opt-btn" onclick="histRedo()" id="topRedoBtn" title="Redo Ctrl+Y"><i class="fa fa-rotate-right"></i></button>
  <div class="tb-sep"></div>
  <span class="coin-badge" id="coinBadge">⬡ —</span>
  <div class="dropdown">
    <button class="tb-user dropdown-toggle" data-bs-toggle="dropdown">
      <i class="fa fa-user-circle"></i>
      @User.Identity!.Name?.Split("@")[0]
    </button>
    <ul class="dropdown-menu dropdown-menu-end" style="background:var(--panel);border-color:var(--bdr2)">
      <li><a class="dropdown-item" href="/Dashboard" style="color:var(--txt);font-size:12px"><i class="fa fa-gauge me-2"></i>Dashboard</a></li>
      <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
      <li>
        <form asp-controller="Account" asp-action="Logout" method="post">
          @Html.AntiForgeryToken()
          <button type="submit" class="dropdown-item" style="color:var(--err);font-size:12px;background:transparent;border:none;width:100%;text-align:left">
            <i class="fa fa-sign-out-alt me-2"></i>Logout
          </button>
        </form>
      </li>
    </ul>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════════
     CONTEXT OPTIONS BAR (below topbar, tool-sensitive)
     ═══════════════════════════════════════════════════════ -->
<div class="optbar" id="optBar">
  <!-- Default: Selection options -->
  <div id="ob-select" class="d-flex align-items-center gap-1" style="flex-wrap:nowrap">
    <span class="ob-lbl">W</span><input type="number" class="ob-input" id="obW" onchange="setPropFromBar('width',+this.value)">
    <span class="ob-lbl">H</span><input type="number" class="ob-input" id="obH" onchange="setPropFromBar('height',+this.value)">
    <div class="ob-sep"></div>
    <span class="ob-lbl">X</span><input type="number" class="ob-input" id="obX" onchange="setPropFromBar('left',+this.value)">
    <span class="ob-lbl">Y</span><input type="number" class="ob-input" id="obY" onchange="setPropFromBar('top',+this.value)">
    <div class="ob-sep"></div>
