@* _ChatLayout.cshtml – fixed layout, all logic moved to ~/js/chat.js *@
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1.0" />
    <title>@ViewData["Title"] - AkkuChatbot</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --bg:#0d1117;--bg2:#161b22;--bg3:#21262d;--bgh:#30363d;
            --bdr:#30363d;--txt:#e6edf3;--txt2:#b0b8c4;
            --acc:#2f81f7;--acc2:#388bfd;--ubub:#4E485A;--bbub:#21262d;
            --coin:#f0c040;--err:#f85149;--ok:#3fb950;--sw:262px;
        }
        [data-theme="light"]{
            --bg:#ffffff;--bg2:#f6f8fa;--bg3:#eaeef2;--bgh:#d0d7de;
            --bdr:#d0d7de;--txt:#1f2328;--txt2:#4a5568;
            --ubub:#0969da;--bbub:#eaeef2;
        }
        *{box-sizing:border-box;margin:0;padding:0}
        body{background:var(--bg);color:var(--txt);font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;height:100vh;overflow:hidden}
        .top-bar{height:52px;background:var(--bg2);border-bottom:1px solid var(--bdr);display:flex;align-items:center;padding:0 10px;gap:8px;position:fixed;top:0;left:0;right:0;z-index:100;flex-wrap:nowrap}
        .brand{font-weight:700;font-size:1rem;color:var(--acc);white-space:nowrap}
        .spacer{flex:1}
        .coin-badge{background:#2d2208;color:var(--coin);border:1px solid #6e4c10;padding:3px 10px;border-radius:20px;font-weight:600;font-size:.8rem;white-space:nowrap}
        .top-btn{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);padding:4px 10px;border-radius:6px;cursor:pointer;font-size:.8rem;transition:background .2s;white-space:nowrap;text-decoration:none}
        .top-btn:hover{background:var(--bgh)}
        .admin-btn{background:#f85149;color:#fff;border-color:#f85149}
        .admin-btn:hover{background:#da3633;color:#fff}
        .capability-badges{display:flex;gap:4px;align-items:center}
        .cap-badge{display:none;font-size:.68rem;padding:2px 7px;border-radius:10px;font-weight:600;border:1px solid}
        .cap-badge.web{background:#0c2a5c;color:#58a6ff;border-color:#1d4a8f}
        .cap-badge.vis{background:#0c3d20;color:#3fb950;border-color:#196d35}
        .cap-badge.cod{background:#2d1b5e;color:#bc8cff;border-color:#5a3699}
        .cap-badge.rea{background:#3d2208;color:#f0c040;border-color:#7d5010}
        .chat-wrapper{display:flex;height:calc(100vh - 52px);margin-top:52px}
        .sidebar{width:var(--sw);background:var(--bg2);border-right:1px solid var(--bdr);display:flex;flex-direction:column;flex-shrink:0;transition:width .25s;overflow:hidden}
        .sidebar.collapsed{width:0}
        .sidebar-header{padding:10px}
        .new-chat-btn{width:100%;background:var(--acc);color:#fff;border:none;padding:8px;border-radius:8px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;transition:background .2s}
        .new-chat-btn:hover{background:var(--acc2)}
        .model-wrap{padding:8px 10px;border-bottom:1px solid var(--bdr)}
        .model-wrap label{font-size:.68rem;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;display:flex;align-items:center;justify-content:space-between}
        .model-sel{width:100%;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);padding:6px 8px;border-radius:6px;font-size:.82rem;cursor:pointer}
        .model-sel:focus{outline:none;border-color:var(--acc)}
        .sessions-list{flex:1;overflow-y:auto;padding:6px}
        .sessions-list::-webkit-scrollbar{width:3px}
        .sessions-list::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:3px}
        .sess-item,.group-item{padding:7px 8px;border-radius:7px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:background .15s;margin-bottom:2px;position:relative}
        .sess-item:hover,.group-item:hover{background:var(--bgh)}
        .sess-item.active,.group-item.active{background:var(--bg3);border:1px solid var(--bdr)}
        .sess-name,.group-name{flex:1;font-size:.8rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .sess-acts,.group-acts{display:none;gap:3px}
        .sess-item:hover .sess-acts,.group-item:hover .group-acts{display:flex}
        .sess-act,.group-act{background:none;border:none;color:var(--txt2);cursor:pointer;padding:2px 3px;border-radius:3px;font-size:.72rem}
        .sess-act:hover,.group-act:hover{background:var(--bdr);color:var(--txt)}
        .chat-main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}
        .msgs-area{flex:1;overflow-y:auto;padding:16px 12px;scroll-behavior:smooth;will-change:scroll-position}
        .msgs-area::-webkit-scrollbar{width:4px}
        .msgs-area::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:4px}
        .msg-group{margin-bottom:14px;position:relative;content-visibility:auto;contain-intrinsic-size:auto 80px}
        .msg-row{display:flex;gap:0;margin-bottom:3px}
        .msg-row.user{flex-direction:row-reverse}
        .msg-bubble{max-width:82%;padding:9px 13px;border-radius:12px;font-size:.88rem;line-height:1.65;word-break:break-word;position:relative}
        .msg-bubble.user{background:var(--ubub);color:#fff;border-bottom-right-radius:3px;margin-left:auto}
        .msg-bubble.bot{background:var(--bbub);border:1px solid var(--bdr);border-bottom-left-radius:3px}
        .msg-bubble pre{background:#0d1117;border:1px solid var(--bdr);border-radius:6px;padding:10px;overflow-x:auto;margin:6px 0;font-size:.78rem}
        .msg-bubble code{font-family:'Consolas',monospace;font-size:.82rem}
        .msg-bubble img{max-width:100%;border-radius:6px;margin:4px 0}
        .msg-bubble p{margin:0 0 6px}
        .msg-bubble ul,.msg-bubble ol{margin:4px 0 4px 18px}
        .msg-actions{display:flex;align-items:center;gap:6px;padding:0 2px;margin-top:2px;opacity:0;transition:opacity .15s;font-size:.68rem;color:var(--txt2)}
        .msg-group:hover .msg-actions{opacity:1}
        .msg-actions.user{justify-content:flex-end}
        .msg-actions.bot{justify-content:flex-start}
        .msg-time{font-size:.67rem;color:var(--txt2)}
        .act-btn{background:none;border:none;color:var(--txt2);cursor:pointer;padding:2px 6px;border-radius:4px;font-size:.68rem;display:inline-flex;align-items:center;gap:3px;transition:all .15s}
        .act-btn:hover{background:var(--bg3);color:var(--acc)}
        .ctx-toggle{display:inline-flex;align-items:center;gap:4px;cursor:pointer;padding:2px 6px;border-radius:4px;transition:background .15s}
        .ctx-toggle:hover{background:var(--bg3)}
        .ctx-toggle input{width:12px;height:12px;cursor:pointer;accent-color:var(--acc);margin:0}
        .ctx-toggle.excluded{color:var(--err);text-decoration:line-through;opacity:.6}
        .welcome{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;gap:12px}
        .welcome h2{font-size:1.7rem;font-weight:700}
        .welcome p{color:var(--txt2);font-size:.9rem}
        .quick-starters{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;max-width:480px;margin-top:8px}
        .quick-btn{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);padding:6px 14px;border-radius:20px;font-size:.78rem;cursor:pointer;transition:all .2s}
        .quick-btn:hover{border-color:var(--acc);color:var(--acc)}
        .input-area{padding:8px 12px 10px;background:var(--bg2);border-top:1px solid var(--bdr);flex-shrink:0}
        .input-toolbar{display:flex;gap:5px;margin-bottom:6px;align-items:center;flex-wrap:nowrap;overflow-x:auto}
        .input-toolbar::-webkit-scrollbar{height:2px}
        .tool-btn{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);min-width:32px;height:32px;border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.8rem;transition:all .15s;position:relative;flex-shrink:0}
        .tool-btn:hover{border-color:var(--acc);color:var(--acc);background:var(--bgh)}
        .tool-btn.active{background:var(--acc);color:#fff;border-color:var(--acc)}
        .tool-btn input[type="file"]{position:absolute;opacity:0;width:100%;height:100%;cursor:pointer;font-size:0}
        .path-wrap{flex:1;min-width:140px;display:flex;gap:4px}
        .path-input{flex:1;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);border-radius:6px;padding:5px 10px;font-size:.75rem;min-width:0;transition:border-color .2s}
        .path-input:focus{outline:none;border-color:var(--acc)}
        .attach-preview{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:6px;min-height:0}
        .a-chip{background:var(--bg3);border:1px solid var(--bdr);padding:4px 10px;border-radius:15px;font-size:.74rem;display:inline-flex;align-items:center;gap:6px;max-width:260px;transition:all .2s}
        .a-chip:hover{border-color:var(--acc)}
        .a-chip span{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
        .a-chip button{background:none;border:none;color:var(--err);cursor:pointer;font-size:.85rem;padding:0;line-height:1}
        .input-row{display:flex;gap:7px;align-items:flex-end}
        .voice-wrap{display:flex;gap:3px;align-items:flex-end;flex-shrink:0}
        .voice-btn{width:38px;height:38px;border-radius:8px;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);font-size:.9rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
        .voice-btn.rec{background:var(--err);color:#fff;border-color:var(--err)}
        .lang-sel{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);padding:3px 4px;border-radius:6px;font-size:.7rem;cursor:pointer;height:28px}
        .input-box{flex:1;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);border-radius:10px;padding:9px 12px;font-size:.88rem;resize:none;min-height:42px;max-height:180px;transition:border-color .2s;line-height:1.5;font-family:inherit}
        .input-box:focus{outline:none;border-color:var(--acc)}
        .send-btn{width:42px;height:42px;border-radius:10px;background:var(--acc);border:none;color:#fff;font-size:.95rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s;flex-shrink:0}
        .send-btn:hover{background:var(--acc2)}
        .send-btn:disabled{background:var(--bgh);cursor:not-allowed}
        .status-bar{display:flex;gap:10px;font-size:.68rem;color:var(--txt2);margin-top:5px;align-items:center;flex-wrap:wrap}
        .model-info-panel{width:256px;background:var(--bg2);border-left:1px solid var(--bdr);padding:14px;overflow-y:auto;flex-shrink:0;display:none;flex-direction:column;gap:12px}
        .model-info-panel.open{display:flex}
        .cap-tag{display:inline-block;background:var(--bg3);border:1px solid var(--bdr);border-radius:12px;padding:2px 8px;font-size:.7rem;margin:2px}
        .cap-tag.yes{border-color:var(--ok);color:var(--ok)}
        .cap-tag.no{color:var(--txt2);opacity:.5}
        .param-section{border-top:1px solid var(--bdr);padding-top:12px}
        .param-row{margin-bottom:11px}
        .param-label{display:flex;justify-content:space-between;font-size:.75rem;margin-bottom:3px}
        .param-label span:last-child{color:var(--acc);font-weight:600}
        .param-hint{font-size:.63rem;color:var(--txt2);margin-top:2px}
        input[type="range"]{-webkit-appearance:none;width:100%;height:5px;border-radius:3px;background:var(--bgh);outline:none;cursor:pointer}
        input[type="range"]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;background:var(--acc);cursor:pointer}
        input[type="range"]::-moz-range-thumb{width:14px;height:14px;border-radius:50%;background:var(--acc);cursor:pointer;border:none}
        .param-btn{width:100%;padding:7px;border-radius:6px;font-size:.8rem;cursor:pointer;border:1px solid var(--bdr);margin-top:5px;transition:all .2s}
        .param-btn.primary{background:var(--acc);color:#fff;border-color:var(--acc)}
        .param-btn.primary:hover{background:var(--acc2)}
        .param-btn.secondary{background:var(--bg3);color:var(--txt)}
        .param-btn.secondary:hover{background:var(--bgh)}
        .thinking-row{padding:8px 12px;display:flex;align-items:center;gap:10px}
        .thinking-dots{display:flex;gap:5px}
        .thinking-dots span{width:7px;height:7px;background:var(--txt2);border-radius:50%;display:inline-block}
        .skeleton-message{height:60px;margin:8px 0;border-radius:12px;background:linear-gradient(90deg,var(--bg3) 25%,var(--bgh) 50%,var(--bg3) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
        @@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
        .sidebar-footer{margin-top:auto;padding:10px;border-top:1px solid var(--bdr);flex-shrink:0}
        .sidebar-footer a,.sidebar-footer button.footer-link{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;color:var(--txt);text-decoration:none;font-size:.82rem;transition:background .2s;background:none;border:none;width:100%;cursor:pointer;text-align:left}
        .sidebar-footer a:hover,.sidebar-footer button.footer-link:hover{background:var(--bg3)}
        @@keyframes blink{0%,49%{opacity:1}50%,100%{opacity:0}}
        @@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}
        .msg-group{animation:fadeIn .2s ease}
        .thinking-dots span:nth-child(1){animation:blink .9s infinite 0s}
        .thinking-dots span:nth-child(2){animation:blink .9s infinite .3s}
        .thinking-dots span:nth-child(3){animation:blink .9s infinite .6s}
        @@media (prefers-reduced-motion:reduce){ .msg-group{animation:none} .thinking-dots span{animation:none;opacity:.5} .skeleton-message{animation:none;background:var(--bgh)} }
        ::-webkit-scrollbar{width:4px;height:4px}
        ::-webkit-scrollbar-track{background:transparent}
        ::-webkit-scrollbar-thumb{background:var(--bdr);border-radius:4px}
        .gen-img-wrap{margin:10px 0;border-radius:12px;overflow:hidden;border:1px solid var(--bdr);background:var(--bg3);display:inline-block;max-width:100%}
        .chat-gen-img{display:block;max-width:100%;max-height:480px;object-fit:contain;cursor:zoom-in;transition:transform .2s ease}
        .chat-gen-img:hover{transform:scale(1.01)}
        .gen-img-actions{display:flex;gap:6px;padding:8px 10px;background:var(--bg2);flex-wrap:wrap}
        .img-act-btn{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);padding:4px 10px;border-radius:6px;font-size:.73rem;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:4px;transition:all .15s}
        .img-act-btn:hover{border-color:var(--acc);color:var(--acc)}
        .img-err{padding:12px 16px;color:var(--err);font-size:.8rem}
        .chat-link{color:var(--acc);text-decoration:none;border-bottom:1px solid transparent;transition:border-color .15s}
        .chat-link:hover{border-bottom-color:var(--acc)}
        @@media(max-width:768px){ .sidebar{position:fixed;z-index:200;height:calc(100vh - 52px);top:52px} .model-info-panel{display:none!important} .msg-bubble{max-width:90%} .path-wrap{display:none} }
        /* Workspace modal */
        .workspace-modal{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;}
        .workspace-content{background:var(--bg2);border:1px solid var(--bdr);border-radius:12px;width:80%;max-width:700px;max-height:80vh;display:flex;flex-direction:column;padding:16px;}
        .workspace-list{flex:1;overflow-y:auto;font-size:.85rem;}
        .workspace-item{display:flex;align-items:center;gap:8px;padding:5px 8px;cursor:pointer;border-radius:4px;}
        .workspace-item:hover{background:var(--bgh);}
        .workspace-item.folder{font-weight:600;}
        /* Mermaid */
        .mermaid-wrap{margin:10px 0;background:var(--bg3);border:1px solid var(--bdr);border-radius:8px;padding:12px;overflow-x:auto;}
        .mermaid-wrap svg{max-width:100%;height:auto;}
        .mermaid-diagram{min-height:40px;display:flex;align-items:center;justify-content:center;color:var(--txt2);font-size:.8rem;}
        /* Group sessions sub-list */
        .group-sessions{padding-left:12px;display:none;}
        .group-sessions.open{display:block;}
        .group-sess-item{padding:4px 8px;border-radius:5px;font-size:.76rem;cursor:pointer;display:flex;align-items:center;gap:6px;color:var(--txt2);}
        .group-sess-item:hover{background:var(--bgh);color:var(--txt);}
        /* Profile badge */
        .profile-badge{display:inline-block;font-size:.65rem;padding:1px 6px;border-radius:8px;border:1px solid var(--bdr);background:var(--bg3);color:var(--txt2);margin-left:4px;vertical-align:middle;}
        .profile-badge.coder{background:#1a1040;border-color:#5a3699;color:#bc8cff;}
        .profile-badge.reasoning{background:#2d1e08;border-color:#7d5010;color:#f0c040;}
        .profile-badge.creative{background:#0a2a1a;border-color:#196d35;color:#3fb950;}
        .profile-badge.analyst{background:#0c2a5c;border-color:#1d4a8f;color:#58a6ff;}
        /* Prompt Templates Modal */
        .tpl-modal{position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.72);display:flex;align-items:center;justify-content:center;}
        .tpl-content{background:var(--bg2);border:1px solid var(--bdr);border-radius:14px;width:92%;max-width:780px;max-height:85vh;display:flex;flex-direction:column;overflow:hidden;}
        .tpl-header{padding:14px 16px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:10px;}
        .tpl-search{flex:1;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);border-radius:8px;padding:6px 12px;font-size:.85rem;}
        .tpl-search:focus{outline:none;border-color:var(--acc);}
        .tpl-cats{display:flex;gap:6px;padding:10px 16px;border-bottom:1px solid var(--bdr);flex-wrap:wrap;}
        .tpl-cat-btn{background:var(--bg3);border:1px solid var(--bdr);color:var(--txt2);padding:4px 12px;border-radius:16px;font-size:.76rem;cursor:pointer;transition:all .15s;}
        .tpl-cat-btn:hover,.tpl-cat-btn.active{background:var(--acc);color:#fff;border-color:var(--acc);}
        .tpl-body{flex:1;overflow-y:auto;padding:14px 16px;display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:10px;}
        .tpl-card{background:var(--bg3);border:1px solid var(--bdr);border-radius:10px;padding:12px;cursor:pointer;transition:border-color .15s;}
        .tpl-card:hover{border-color:var(--acc);}
        .tpl-card h5{font-size:.82rem;font-weight:600;margin-bottom:5px;}
        .tpl-card p{font-size:.73rem;color:var(--txt2);margin-bottom:8px;line-height:1.5;}
        .tpl-use-btn{background:var(--acc);color:#fff;border:none;border-radius:6px;padding:4px 12px;font-size:.73rem;cursor:pointer;width:100%;}
        .tpl-use-btn:hover{background:var(--acc2);}
        /* Search results modal */
        .search-modal{position:fixed;inset:0;z-index:9998;background:rgba(0,0,0,0.65);display:flex;align-items:center;justify-content:center;}
        .search-content{background:var(--bg2);border:1px solid var(--bdr);border-radius:14px;width:88%;max-width:680px;max-height:80vh;display:flex;flex-direction:column;overflow:hidden;}
        .search-result-item{padding:10px 14px;border-bottom:1px solid var(--bdr);cursor:pointer;transition:background .15s;}
        .search-result-item:hover{background:var(--bgh);}
        .search-result-item:last-child{border-bottom:none;}
        @@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
    </style>
</head>
<body>
<!-- ══════════ TOP BAR ══════════ -->
<div class="top-bar">
  <button class="top-btn" onclick="toggleSidebar()" title="Toggle sidebar" aria-label="Toggle sidebar"><i class="fa fa-bars"></i></button>
  <span class="brand">🤖 AkkuChatbot</span>
  <span class="spacer"></span>
  <div class="capability-badges">
    <span class="cap-badge web" id="webBadge">🌐 Web</span>
    <span class="cap-badge vis" id="visBadge">👁 Vision</span>
    <span class="cap-badge cod" id="codBadge">💻 Code</span>
    <span class="cap-badge rea" id="reaBadge">🧠 Thinking</span>
  </div>
  <span style="font-size:.7rem;color:var(--txt2);white-space:nowrap" id="tokenStatus"></span>
  <span class="coin-badge">🪙 <span id="coinDisplay">…</span></span>
  @if (User.IsInRole("Admin"))
  { <a href="/Admin" class="top-btn admin-btn">⚙️ Admin</a> }
  <button class="top-btn" id="exportPdfBtn" onclick="exportPDF()" title="Export chat as PDF" style="display:none"><i class="fa fa-file-pdf"></i> PDF</button>
  <div class="dropdown">
    <button class="top-btn dropdown-toggle" data-bs-toggle="dropdown" title="Tools"><i class="fa fa-tools"></i> Tools</button>
    <ul class="dropdown-menu dropdown-menu-end" style="background:var(--bg2);border:1px solid var(--bdr);min-width:190px">
      <li><h6 class="dropdown-header" style="color:var(--txt2);font-size:.68rem;letter-spacing:.5px">TOOLS</h6></li>
      <li><a class="dropdown-item" href="/Tools/ImageToText" style="color:var(--txt);font-size:.83rem"><span class="me-2">📝</span>OCR — Image to Text</a></li>
      <li><a class="dropdown-item" href="/Tools/VoiceToText" style="color:var(--txt);font-size:.83rem"><span class="me-2">🎤</span>Voice Typing</a></li>
      <li><a class="dropdown-item" href="/Tools/ImageEditor" style="color:var(--txt);font-size:.83rem"><span class="me-2">🎨</span>Image Editor</a></li>
      <li><button class="dropdown-item" onclick="showPromptTemplates()" style="color:var(--txt);font-size:.83rem;width:100%;text-align:left;background:none;border:none"><span class="me-2">📋</span>Prompt Templates</button></li>
      <li><button class="dropdown-item" onclick="openWorkspaceBrowser()" style="color:var(--txt);font-size:.83rem;width:100%;text-align:left;background:none;border:none"><span class="me-2">📂</span>Workspace Browser</button></li>
      <li><hr class="dropdown-divider" style="border-color:var(--bdr)"></li>
      <li><a class="dropdown-item" href="/Software" style="color:var(--txt);font-size:.83rem"><span class="me-2">📦</span>Software Library</a></li>
    </ul>
  </div>
  <button class="top-btn" onclick="toggleTheme()" title="Toggle theme"><i class="fa fa-moon"></i></button>
  <button class="top-btn" onclick="toggleInfoPanel()" title="Model settings &amp; info"><i class="fa fa-sliders-h"></i></button>
  <div class="dropdown">
    <button class="top-btn dropdown-toggle" data-bs-toggle="dropdown">👤 @User.Identity!.Name?.Split('@')[0]</button>
    <ul class="dropdown-menu dropdown-menu-end">
      <li><a class="dropdown-item" href="/Dashboard">📊 Dashboard</a></li>
      <li><a class="dropdown-item" href="/Coin/History">🪙 Coin History</a></li>
      <li><hr class="dropdown-divider"></li>
      <li>
        <form asp-controller="Account" asp-action="Logout" method="post">
          @Html.AntiForgeryToken()
          <button type="submit" class="dropdown-item text-danger">🚪 Logout</button>
        </form>
      </li>
    </ul>
  </div>
</div>

<div class="chat-wrapper">
  <!-- ── SIDEBAR ── -->
  <div class="sidebar" id="sidebar" role="navigation" aria-label="Chat sessions">
    <div class="sidebar-header">
      <button class="new-chat-btn" onclick="startNewChat()" aria-label="Start new chat"><i class="fa fa-plus"></i> New Chat</button>
    </div>

    <div class="model-wrap">
      <label>
        <span>AI Model</span>
        <button onclick="refreshModels()" style="background:none;border:none;color:var(--txt2);font-size:.7rem;cursor:pointer" title="Refresh model list"><i class="fa fa-sync" id="refreshIcon"></i></button>
      </label>
      <select class="model-sel" id="modelSelect" onchange="onModelChange(this.value)" aria-label="Select AI model">
        @if (ViewBag.Models != null)
        { @foreach (var m in ViewBag.Models) { <option value="@m.ModelId">@m.Icon @m.DisplayName</option> } }
      </select>
    </div>

    <!-- ═══ GROUPS SECTION ═══ -->
    <div style="padding:8px 10px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between;">
      <span style="font-size:.68rem;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;">Groups</span>
      <button onclick="showGroupCreate()" style="background:none;border:none;color:var(--acc);cursor:pointer;font-size:.8rem;" title="Create group">+</button>
    </div>
    <div class="sessions-list" id="groupsList" style="max-height:200px;flex:none;"></div>

    <div style="padding:8px 10px;border-bottom:1px solid var(--bdr);">
      <span style="font-size:.68rem;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;">Sessions</span>
    </div>
    <div class="sessions-list" id="sessionsList" role="list" aria-label="Chat sessions list">
      @if (ViewBag.Sessions != null)
      { @foreach (var s in ViewBag.Sessions) {
        <div class="sess-item" id="sess-@s.Id" role="listitem" onclick="if(!this.classList.contains('active')) loadSession(@s.Id)">
          <span style="font-size:.75rem;opacity:.5">💬</span>
          <span class="sess-name" title="@s.Name">@s.Name</span>
          <div class="sess-acts">
            <button class="sess-act" title="Add to group" onclick="event.stopPropagation();showAddToGroup(@s.Id)">📁</button>
            <button class="sess-act" title="Rename" onclick="event.stopPropagation();renameSession(@s.Id,@Html.Raw("'" + s.Name.Replace("'","\\'") + "'"))">✏️</button>
            <button class="sess-act" title="Delete" style="color:var(--err)" onclick="event.stopPropagation();deleteSession(@s.Id)">🗑</button>
          </div>
        </div>
      } }
    </div>

    <!-- ── SIDEBAR FOOTER ── -->
    <div class="sidebar-footer">
      <button class="footer-link" onclick="openWorkspaceBrowser()"><span>📂</span> Workspace Browser</button>
      <a href="/Tools/PromptTemplates" class="tpl-btn" style="display:inline-block; text-align:center; margin-top:5px;">
    <i class="fa fa-folder-open"></i> Manage All Templates
</a>
      <button class="footer-link" onclick="showPromptTemplates()"><span>📋</span> Prompt Templates</button>
    </div>
  </div>

  <!-- ── CHAT MAIN ── -->
  <div class="chat-main">
    <div class="msgs-area" id="msgsArea" role="log" aria-live="polite" aria-label="Chat messages">
      <div class="welcome" id="welcomeScreen">
        <div style="font-size:3rem">🤖</div>
        <h2>AkkuChatbot</h2>
        <p>Select a model, then start a new chat or load a previous session.</p>
        <div class="quick-starters">
          <button class="quick-btn" onclick="quickStart('Explain quantum computing simply')">⚛️ Quantum computing</button>
          <button class="quick-btn" onclick="quickStart('Write a Python script to sort a list')">🐍 Python help</button>
          <button class="quick-btn" onclick="quickStart('Summarize the latest AI trends')">🤖 AI trends</button>
          <button class="quick-btn" onclick="quickStart('Help me debug my code')">🔧 Debug code</button>
        </div>
      </div>
    </div>

    <!-- ── INPUT AREA ── -->
    <div class="input-area">
      <div class="input-toolbar">
        <button class="tool-btn" title="Attach image"><i class="fa fa-image"></i><input type="file" id="imageInput" accept="image/*" multiple onchange="handleAttachments(this)"></button>
        <button class="tool-btn" title="Attach file"><i class="fa fa-paperclip"></i><input type="file" id="fileInput" accept=".pdf,.txt,.csv,.json,.md,.py,.js,.cs" multiple onchange="handleAttachments(this)"></button>
        <button class="tool-btn" title="OCR" onclick="triggerOCR()"><i class="fa fa-file-alt"></i></button>
        <button class="tool-btn" id="pathToggleBtn" onclick="togglePathBar()" title="Add path/URL"><i class="fa fa-link"></i></button>
        <div class="path-wrap" id="pathBar" style="display:none">
          <input type="text" id="pathInput" class="path-input" placeholder="📁 /path/to/file or 🌐 URL" onkeydown="if(event.key==='Enter'){event.preventDefault();addPathAttachment()}">
          <button class="tool-btn" onclick="addPathAttachment()"><i class="fa fa-plus"></i></button>
        </div>
        <button class="tool-btn" onclick="openWorkspaceBrowser()" title="Browse workspace"><i class="fa fa-folder-open"></i></button>
        <button class="tool-btn" onclick="showPromptTemplates()" title="Prompt templates"><i class="fa fa-bookmark"></i></button>
        <div style="flex:1"></div>
        <span id="profileIndicator" style="font-size:.68rem;color:var(--txt2);white-space:nowrap;"></span>
      </div>
      <div class="attach-preview" id="attachPreview"></div>
      <div class="input-row">
        <div class="voice-wrap">
          <button class="voice-btn" id="voiceBtn" onclick="toggleVoice()" title="Voice input"><i class="fa fa-microphone"></i></button>
          <select class="lang-sel" id="voiceLang" title="Voice language">
            <option value="en-US">EN</option>
            <option value="ta-IN">தமிழ்</option>
            <option value="hi-IN">हिन्दी</option>
            <option value="te-IN">తెలుగు</option>
          </select>
        </div>
        <textarea class="input-box" id="msgInput" rows="1" placeholder="Type a message… (Enter to send, Shift+Enter for new line)" onkeydown="handleKey(event)" oninput="autoResize(this)" aria-label="Message input"></textarea>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()" title="Send message" aria-label="Send message"><i class="fa fa-paper-plane"></i></button>
      </div>
      <div class="status-bar">
        <span>🪙 <strong id="statusBal">…</strong></span>
        <span id="statusTok" style="display:none">⚡ <strong id="tokCount">0</strong> tokens</span>
        <span id="statusSess" style="display:none;margin-left:auto;opacity:.7">📂 <strong id="sessNameStatus"></strong></span>
      </div>
    </div>
  </div>

  <!-- ── MODEL INFO PANEL ── -->
  <div class="model-info-panel" id="modelInfoPanel">
    <div style="display:flex;justify-content:space-between;align-items:center">
      <h6 style="font-weight:700;font-size:.9rem;margin:0">Model Info</h6>
      <button onclick="toggleInfoPanel()" style="background:none;border:none;color:var(--txt2);cursor:pointer;font-size:.85rem" aria-label="Close model info">✕</button>
    </div>
    <div id="modelInfoContent"><p style="color:var(--txt2);font-size:.8rem">Select a model to see details.</p></div>
    <div class="param-section" id="modelParams" style="display:none">
      <div style="font-size:.72rem;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:10px">Parameters</div>
      <div class="param-row">
        <div class="param-label"><span>Temperature</span><span id="tempVal">0.70</span></div>
        <input type="range" id="paramTemp" min="0" max="2" step="0.05" value="0.70" oninput="updateParamLabel('tempVal',this.value,2)">
        <div class="param-hint">Higher = creative · Lower = focused</div>
      </div>
      <div class="param-row">
        <div class="param-label"><span>Top-P</span><span id="topPVal">0.90</span></div>
        <input type="range" id="paramTopP" min="0.1" max="1" step="0.05" value="0.90" oninput="updateParamLabel('topPVal',this.value,2)">
        <div class="param-hint">Nucleus sampling threshold</div>
      </div>
      <div class="param-row">
        <div class="param-label"><span>Max Tokens</span><span id="maxTokVal">4096</span></div>
        <input type="range" id="paramMaxTok" min="256" max="32768" step="256" value="4096" oninput="updateParamLabel('maxTokVal',this.value,0)">
        <div class="param-hint">Maximum response length</div>
      </div>
      <div class="param-row">
        <div class="param-label"><span>Context Depth</span><span id="ctxDepthVal">10</span></div>
        <input type="range" id="paramCtxDepth" min="1" max="50" step="1" value="10" oninput="updateParamLabel('ctxDepthVal',this.value,0)">
        <div class="param-hint">Previous messages to include</div>
      </div>
      <div class="param-row">
        <div class="param-label"><span>Repeat Penalty</span><span id="repeatPenVal">1.10</span></div>
        <input type="range" id="paramRepeatPen" min="1" max="2" step="0.05" value="1.10" oninput="updateParamLabel('repeatPenVal',this.value,2)">
        <div class="param-hint">Penalise repeated tokens</div>
      </div>
      <div class="param-row">
        <div class="param-label" style="margin-bottom:5px"><span>System Prompt</span></div>
        <textarea id="paramSysPrompt" placeholder="Optional system instructions…"
          style="width:100%;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);border-radius:6px;padding:6px 8px;font-size:.75rem;resize:vertical;min-height:60px;font-family:inherit;"></textarea>
      </div>
      <div style="font-size:.72rem;color:var(--txt2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;">Output Profile</div>
      <select id="paramProfile" style="width:100%;background:var(--bg3);border:1px solid var(--bdr);color:var(--txt);border-radius:6px;padding:5px 8px;font-size:.78rem;margin-bottom:8px;" onchange="setProfile(this.value)">
        <option value="default">📝 Default</option>
        <option value="coder">💻 Coder (syntax highlight)</option>
        <option value="reasoning">🧠 Reasoning (collapsible thoughts)</option>
        <option value="creative">✨ Creative (enhanced typography)</option>
        <option value="analyst">📊 Analyst (table-friendly)</option>
      </select>
      <button class="param-btn secondary" onclick="resetParams()">↺ Reset Defaults</button>
      <button class="param-btn primary" onclick="saveParams()">✓ Apply</button>
    </div>
  </div>
</div>

<!-- ═══ WORKSPACE MODAL ═══ -->
<div id="workspaceModal" class="workspace-modal" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
  <div class="workspace-content">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
      <strong>📂 Workspace Browser</strong>
      <button onclick="document.getElementById('workspaceModal').style.display='none'" style="background:none;border:none;color:var(--txt2);cursor:pointer;font-size:1rem;">✕</button>
    </div>
    <div style="display:flex;gap:6px;margin-bottom:6px;">
      <input type="text" id="workspacePathInput" placeholder="Set workspace path (e.g. C:\Projects or /home/user)"
        style="flex:1;padding:6px;border-radius:4px;border:1px solid var(--bdr);background:var(--bg3);color:var(--txt);font-size:.8rem;">
      <button onclick="setWorkspacePath(document.getElementById('workspacePathInput').value)" class="tool-btn" title="Set path"><i class="fa fa-check"></i></button>
    </div>
    <div id="workspaceBreadcrumb" style="font-size:.72rem;color:var(--acc);margin-bottom:6px;cursor:pointer;" onclick="loadWorkspaceDir('')">
      📂 / (root)
    </div>
    <div style="display:flex;gap:6px;margin-bottom:6px;font-size:.74rem;color:var(--txt2);">
      <button onclick="workspaceGoUp()" class="tool-btn" title="Go up" style="font-size:.7rem;padding:2px 8px;width:auto;height:24px;"><i class="fa fa-arrow-up"></i> Up</button>
      <span id="wsSelectedCount" style="margin-left:auto;"></span>
      <button id="wsSendAllBtn" onclick="sendAllSelectedWorkspace()" class="tool-btn active" title="Send selected to chat" style="display:none;font-size:.7rem;padding:2px 8px;width:auto;height:24px;">📤 Send Selected</button>
    </div>
    <div id="workspaceList" class="workspace-list"></div>
  </div>
</div>

<!-- ═══ PROMPT TEMPLATES MODAL ═══ -->
<div id="promptTemplatesModal" class="tpl-modal" style="display:none;" onclick="if(event.target===this)closePromptTemplates()">
  <div class="tpl-content">
    <div class="tpl-header">
      <span style="font-size:1.1rem;font-weight:700;">📋 Prompt Templates</span>
      <input type="text" class="tpl-search" id="tplSearch" placeholder="Search templates…" oninput="filterTemplates(this.value)">
      <button onclick="closePromptTemplates()" style="background:none;border:none;color:var(--txt2);cursor:pointer;font-size:1.1rem;padding:0 4px;">✕</button>
    </div>
    <div class="tpl-cats">
      <button class="tpl-cat-btn active" onclick="filterCategory('all',this)">All</button>
      <button class="tpl-cat-btn" onclick="filterCategory('image',this)">🖼️ Image</button>
      <button class="tpl-cat-btn" onclick="filterCategory('code',this)">💻 Code</button>
      <button class="tpl-cat-btn" onclick="filterCategory('writing',this)">✍️ Writing</button>
      <button class="tpl-cat-btn" onclick="filterCategory('analysis',this)">📊 Analysis</button>
      <button class="tpl-cat-btn" onclick="filterCategory('translate',this)">🌐 Translate</button>
      <button class="tpl-cat-btn" onclick="filterCategory('tamil',this)">🇮🇳 Tamil</button>
    </div>
    <div class="tpl-body" id="tplBody"></div>
  </div>
</div>

<!-- ═══ GROUP SEARCH RESULTS MODAL ═══ -->
<div id="groupSearchModal" class="search-modal" style="display:none;" onclick="if(event.target===this)this.style.display='none'">
  <div class="search-content">
    <div style="padding:12px 16px;border-bottom:1px solid var(--bdr);display:flex;justify-content:space-between;align-items:center;">
      <strong>🔍 Search Results</strong>
      <button onclick="document.getElementById('groupSearchModal').style.display='none'" style="background:none;border:none;color:var(--txt2);cursor:pointer;">✕</button>
    </div>
    <div id="searchResultsList" style="flex:1;overflow-y:auto;max-height:60vh;"></div>
  </div>
</div>

<!-- ═══ EXTERNAL SCRIPTS ═══ -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/mermaid/10.9.0/mermaid.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.0/dist/purify.min.js"></script>
<!-- Prism for code highlighting -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css" rel="stylesheet" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-python.min.js"></script>
<!-- Our main chat logic -->
<script src="~/js/chat.js" defer></script>

@{ IgnoreBody(); }
@RenderSection("Scripts", required: false)
</body>
</html> 