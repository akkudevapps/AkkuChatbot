<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>@ViewData["Title"] — Admin | AkkuChatbot</title>
<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
:root{--sb:230px;--top:54px}
body{background:#0d1117;color:#e6edf3;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.admin-top{height:var(--top);background:#161b22;border-bottom:1px solid #30363d;display:flex;align-items:center;padding:0 16px;gap:12px;position:fixed;top:0;left:0;right:0;z-index:200}
.admin-brand{font-weight:700;font-size:1rem;color:#f85149;text-decoration:none;display:flex;align-items:center;gap:6px}
.admin-brand span{color:#e6edf3}
.admin-wrap{display:flex;padding-top:var(--top);min-height:100vh}
.admin-side{width:var(--sb);background:#161b22;border-right:1px solid #30363d;position:fixed;top:var(--top);bottom:0;overflow-y:auto;padding:12px 0}
.side-section{padding:6px 12px;font-size:.68rem;color:#8b949e;text-transform:uppercase;letter-spacing:.6px;margin-top:8px}
.side-link{display:flex;align-items:center;gap:9px;padding:8px 16px;color:#8b949e;text-decoration:none;font-size:.85rem;transition:all .15s;border-left:2px solid transparent}
.side-link:hover{color:#e6edf3;background:#21262d;border-left-color:#30363d}
.side-link.active{color:#2f81f7;background:#1f2d45;border-left-color:#2f81f7;font-weight:600}
.side-link i{width:16px;text-align:center;font-size:.82rem}
.admin-main{margin-left:var(--sb);flex:1;padding:24px;min-width:0}
.stat-card{background:#161b22;border:1px solid #30363d;border-radius:10px;padding:18px;text-align:center}
.stat-card .n{font-size:1.8rem;font-weight:800}
.stat-card .l{font-size:.75rem;color:#8b949e;margin-top:3px}
.page-title{font-size:1.3rem;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:10px}
.admin-card{background:#161b22;border:1px solid #30363d;border-radius:10px;overflow:hidden;margin-bottom:20px}
.admin-card-head{padding:12px 16px;border-bottom:1px solid #30363d;font-weight:600;font-size:.9rem;display:flex;align-items:center;justify-content:space-between;gap:8px}
.admin-table{width:100%;border-collapse:collapse;font-size:.83rem}
.admin-table th{background:#21262d;padding:10px 12px;text-align:left;color:#8b949e;font-weight:500;font-size:.75rem;text-transform:uppercase;letter-spacing:.4px;border-bottom:1px solid #30363d;white-space:nowrap}
.admin-table td{padding:9px 12px;border-bottom:1px solid #21262d;vertical-align:middle}
.admin-table tr:last-child td{border-bottom:none}
.admin-table tr:hover td{background:#1c2128}
.badge-role{padding:2px 8px;border-radius:10px;font-size:.7rem;font-weight:600}
.badge-admin{background:#3d1a1a;color:#f85149;border:1px solid #f85149}
.badge-user{background:#1a3a1a;color:#3fb950;border:1px solid #3fb950}
.badge-active{background:#1a3a1a;color:#3fb950;border:1px solid #3fb950;padding:2px 8px;border-radius:10px;font-size:.7rem}
.badge-inactive{background:#3d1a1a;color:#f85149;border:1px solid #f85149;padding:2px 8px;border-radius:10px;font-size:.7rem}
.coin-pill{background:#2d2208;color:#f0c040;border:1px solid #6e4c10;padding:2px 8px;border-radius:10px;font-size:.75rem;font-weight:600}
.btn-xs{padding:3px 8px;font-size:.72rem;border-radius:5px}
.search-bar{background:#21262d;border:1px solid #30363d;color:#e6edf3;padding:7px 12px;border-radius:8px;font-size:.83rem;width:260px}
.search-bar:focus{outline:none;border-color:#2f81f7}
@@media(max-width:768px){:root{--sb:0px}.admin-side{display:none}.admin-main{margin-left:0}}
</style>
</head>
<body>

<div class="admin-top">
  <a class="admin-brand" href="/Admin">⚙️ <span>Admin Panel</span></a>
  <span style="flex:1"></span>
  <a href="/" style="color:#8b949e;font-size:.82rem;text-decoration:none;margin-right:8px">
    <i class="fa fa-home"></i> Site
  </a>
  <a href="/Chat" style="color:#8b949e;font-size:.82rem;text-decoration:none;margin-right:8px">
    <i class="fa fa-comments"></i> Chat
  </a>
  <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
    <button type="submit" style="background:none;border:none;color:#f85149;font-size:.82rem;cursor:pointer">
      <i class="fa fa-sign-out-alt"></i> Logout
    </button>
  </form>
</div>

<div class="admin-wrap">
  <nav class="admin-side">
    <div class="side-section">Overview</div>
    <a class="side-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")"
       href="/Admin"><i class="fa fa-gauge"></i> Dashboard</a>

    <div class="side-section">Users</div>
    <a class="side-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Users"?"active":"")"
       href="/Admin/Users"><i class="fa fa-users"></i> All Users</a>

    <div class="side-section">Chat Data</div>
    <a class="side-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Sessions"?"active":"")"
       href="/Admin/Sessions"><i class="fa fa-comments"></i> Sessions</a>
    <a class="side-link @(ViewContext.RouteData.Values["action"]?.ToString()=="Transactions"?"active":"")"
       href="/Admin/Transactions"><i class="fa fa-coins"></i> Coin Transactions</a>

    <div class="side-section">Quick Actions</div>
    <a class="side-link" href="#bulkModal" data-bs-toggle="modal">
      <i class="fa fa-gift"></i> Bulk Coins
    </a>
  </nav>

  <main class="admin-main">
    @if (TempData["Success"] != null)
    {
      <div class="alert alert-success alert-dismissible py-2" style="background:#1a3a1a;border-color:#3fb950;color:#3fb950">
        <i class="fa fa-check-circle"></i> @TempData["Success"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
      </div>
    }
    @if (TempData["Error"] != null)
    {
      <div class="alert alert-danger alert-dismissible py-2" style="background:#3d1a1a;border-color:#f85149;color:#f85149">
        <i class="fa fa-exclamation-triangle"></i> @TempData["Error"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
      </div>
    }

    @RenderBody()
  </main>
</div>

<!-- BULK COINS MODAL -->
<div class="modal fade" id="bulkModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content" style="background:#161b22;border:1px solid #30363d;color:#e6edf3">
      <div class="modal-header" style="border-color:#30363d">
        <h5 class="modal-title">🎁 Bulk Add Coins — All Active Users</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form method="post" asp-controller="Admin" asp-action="BulkAddCoins">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label small text-secondary">Coins per user</label>
            <input type="number" name="amount" class="form-control" style="background:#21262d;border-color:#30363d;color:#e6edf3" min="1" max="10000" value="50" required/>
          </div>
          <div class="mb-3">
            <label class="form-label small text-secondary">Reason</label>
            <input type="text" name="reason" class="form-control" style="background:#21262d;border-color:#30363d;color:#e6edf3" placeholder="e.g. Promotional bonus" required/>
          </div>
        </div>
        <div class="modal-footer" style="border-color:#30363d">
          <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-warning btn-sm">🪙 Add to All Users</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
